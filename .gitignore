# .gitignore for Python project with PyCharm on macOS

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Cython build files
*.c
*.so

# Virtual environments
venv/
env/
ENV/
.venv/
.virtualenv/
pipenv/
Pipfile.lock

# PyCharm IDE files
.idea/
*.iml

# macOS system files
.DS_Store
.AppleDouble
.LSOverride

# Test, coverage, and log files
.coverage
coverage.xml
htmlcov/
*.log

# Build and distribution folders
build/
dist/
*.egg-info/
.eggs/
*.egg

# Python packaging
*.pyo
*.pyd
*.pdb

# Jupyter Notebook checkpoints
.ipynb_checkpoints

# Temporary files
*.tmp
*.swp
*.swo

# Other config
*.env
.envrc
.env.*