          "type": "field-system",
          "interface": "Device control interfaces",
          "description": "Provide operational control endpoints."
        }
      ],
      "flows": [
        "Monitor charger health",
        "Push remote commands",
        "Resolve charger incidents",
        "Update charger configuration"
      ]
    },
    {
