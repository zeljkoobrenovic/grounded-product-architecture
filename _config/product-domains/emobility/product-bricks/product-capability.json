{
  "metadata": {
    "title": "Product Capabilities",
    "description": "Outcome-based product capabilities for the eMobility domain, grounded in open charging interoperability, network operations, fleet workflows, and settlement needs.",
    "definitions": {
      "productCapability": "A high-level, outcome-based ability that delivers customer or business value.",
      "productBrick": "A reusable implementation-facing building block used to realize one or more product capabilities."
    },
    "sources": [
      "https://openchargealliance.org/",
      "https://openchargealliance.org/protocols/open-charge-point-protocol/"
    ]
  },
  "capabilities": [
    {
      "id": "operator-connect-any-charger",
      "group": "Charge Point Operator Experience",
      "name": "Connect Any Charger",
      "type": "outcome-based-capability",
      "description": "Help a charge point operator bring new hardware online quickly regardless of vendor.",
      "outcomes": [
        "Faster charger onboarding",
        "Lower vendor-specific setup effort"
      ],
      "brickDependencies": [
        {
          "targetBrickId": "cpcp",
          "type": "composition"
        },
        {
          "targetBrickId": "agdp",
          "type": "composition"
        }
      ],
      "externalSystemsThisCapabilityDependsOn": [
        {
          "system": "EV Chargers",
          "type": "field-system",
          "interface": "OCPP",
          "description": "Provide the physical charging endpoints."
        }
      ],
      "flows": [
        "Register charger",
        "Map charger protocol",
        "Validate connectivity",
        "Activate charger in network"
      ]
    },
    {
      "id": "operator-run-network-remotely",
