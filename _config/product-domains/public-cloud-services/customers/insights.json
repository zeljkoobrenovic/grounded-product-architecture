    {
      "id": "insight-regional-and-sovereign-clouds-shape-procurement",
      "title": "Regional and sovereign cloud requirements keep the market from being purely global",
      "summary": "Alibaba, Tencent, and OVHcloud show that cloud competition is regionally specific. China-centered ecosystems, European sovereignty needs, local certifications, and data residency expectations materially shape buyer shortlists.",
      "implications": [
        "Model regional availability, data residency, and sovereign controls as core product capabilities.",
        "Competition analysis should not collapse regional leaders into a generic challenger bucket."
      ],
      "evidenceUrls": [
        "https://www.businesswire.com/news/home/20250514856295/en/Alibaba-Group-Announces-March-Quarter-2025-and-Fiscal-Year-2025-Results",
