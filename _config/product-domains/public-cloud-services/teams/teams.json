{
  "orgDesign": {
    "domainId": "public-cloud-services",
    "domainName": "Public Cloud Services",
    "companyProfile": "Public-cloud services provider serving startups, enterprises, application builders, platform teams, SREs, security teams, FinOps operators, regulated sectors, partners, and procurement stakeholders.",
    "operatingModel": "Infrastructure teams own core primitives; managed-platform teams own developer, data, and AI services; trust-and-operations teams own governance, security, observability, and FinOps; enterprise-ecosystem teams own migration, support, documentation, marketplace, and partner adoption.",
    "designPrinciples": [
      "Keep compute, storage, networking, and resilience as durable foundations with explicit ownership.",
      "Keep managed application, data, and AI services close to developer activation and workload expansion.",
      "Keep identity, observability, policy, security posture, and FinOps in one operating loop.",
      "Keep migration, marketplace, support, and documentation connected because enterprise adoption depends on the full commercial and implementation path."
    ],
    "staffingPrinciple": "Prefer teams of roughly 7-10 FTE with explicit product-brick ownership and measurable customer outcomes.",
    "groupingPrinciple": "Use top-level groups for infrastructure services, managed platform services, trust and operations, and enterprise ecosystem.",
    "groupLeadershipPrinciple": "Use cross-group leadership around activation, reliability, security, regulated adoption, AI platform expansion, and consumption economics."
  },
