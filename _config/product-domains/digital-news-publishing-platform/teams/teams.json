{
  "orgDesign": {
    "domainId": "digital-news-publishing-platform",
    "domainName": "Digital News Publishing Platform",
    "companyProfile": "Multi-brand consumer media platform centered on audience habit, editorial packaging, subscriptions, premium advertising, and partner monetization.",
    "operatingModel": "Audience teams own direct habit, personalization, registration, and subscriptions. Editorial platform teams own authoring, asset workflows, and distribution packaging. Revenue teams own advertising, commerce, and bundle monetization. Shared platform teams own identity, consent, measurement, and revenue operations.",
    "designPrinciples": [
      "Keep front-door growth, newsletters, and registration close together because known audience growth compounds across the portfolio.",
      "Keep CMS, live publishing, and distribution packaging close to the newsroom because monetization quality starts with publish-time choices.",
      "Keep identity, consent, and measurement tightly coupled to subscriptions and advertising because audience value depends on trusted first-party data."
    ],
    "staffingPrinciple": "Prefer teams of roughly 7-10 FTE with explicit customer or product-brick ownership.",
    "groupingPrinciple": "Use top-level groups for audience growth, editorial platform, revenue and partnerships, and shared foundations.",
    "groupLeadershipPrinciple": "Use lightweight group leadership tied to audience, subscriber, and monetization outcomes."
  },
