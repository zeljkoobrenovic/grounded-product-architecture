{
  "metadata": {
    "title": "Product Capabilities",
    "description": "Outcome-based product capabilities for the Nutrition domain, linking formulation, production, quality, supplier collaboration, and analytics to the underlying product bricks.",
    "definitions": {
      "productCapability": "A high-level, outcome-based ability that delivers customer or business value.",
      "productBrick": "A reusable implementation-facing building block used to realize one or more product capabilities."
    },
    "sources": [
      "https://support.gs1.org/support/solutions/articles/43000734375-what-is-gs1-s-role-in-traceability-"
    ]
  },
  "capabilities": [
    {
      "id": "nutritionist-trust-core-product-data",
      "group": "Formulation User Experience",
      "name": "Trust Core Product Data",
      "type": "outcome-based-capability",
      "description": "Help formulators work from trusted ingredient, nutrient, and specification data.",
      "outcomes": [
        "Less time reconciling data",
        "Higher confidence in starting assumptions"
      ],
      "brickDependencies": [
        {
          "targetBrickId": "indm",
          "type": "composition"
        },
        {
          "targetBrickId": "smpm",
          "type": "composition"
        },
        {
          "targetBrickId": "rdum",
          "type": "composition"
        }
      ],
      "externalSystemsThisCapabilityDependsOn": [
        {
          "system": "Reference Data and Regulatory Sources",
          "type": "reference-data",
          "interface": "Reference feeds",
          "description": "Provide market and regulatory inputs."
        }
      ],
      "flows": [
        "Open ingredient record",
        "Review nutrient profile",
        "Compare specification versions",
        "Confirm base data set"
      ]
    },
