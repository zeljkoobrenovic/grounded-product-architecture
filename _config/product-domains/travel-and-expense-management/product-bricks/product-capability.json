{
  "metadata": {
    "title": "Product Experiences",
    "description": "Outcome-based product experiences for the Travel and Expense Management domain, covering expense capture, travel control, cards, finance automation, and adjacent AP workflows.",
    "definitions": {
      "productBrick": "A reusable implementation-facing building block used to realize one or more product experiences.",
      "productCapability": "A high-level, outcome-based experience that delivers customer or business value."
    },
    "sources": [
      "https://www.rydoo.com/",
      "https://www.rydoo.com/expense-management-software/",
      "https://www.rydoo.com/travel-expense-management/",
      "https://www.rydoo.com/cards/",
      "https://www.rydoo.com/integrations/",
      "https://www.rydoo.com/smart-audit/",
      "https://www.rydoo.com/semine/"
    ],
    "flowModelVersion": "3.2",
    "flowModelNote": "Each experience carries only experience-specific flows. Each flow step lists the bricks and external systems used inside that experience."
  },
  "rootGroups": [
    {
      "name": "Employee Spend Capture",
      "description": "",
      "subGroups": [],
      "capabilities": [
        {
          "id": "submit-expenses-in-minutes",
          "name": "Submit Expenses in Minutes Instead of at Month End",
          "type": "outcome-based-experience",
          "description": "Help employees and managers capture receipts, complete claims, and route approvals with minimal friction.",
          "outcomes": [
            "Lower time to submit an expense",
            "Higher active employee submission rate"
          ],
          "brickDependencies": [
            {
              "targetBrickId": "rcpt",
              "type": "composition"
            },
            {
              "targetBrickId": "mobl",
              "type": "composition"
            },
            {
              "targetBrickId": "expf",
              "type": "composition"
            },
            {
              "targetBrickId": "cate",
              "type": "composition"
            },
            {
              "targetBrickId": "aprv",
              "type": "composition"
            }
          ],
          "flows": [
            {
              "id": "submit-expenses-flow",
              "title": "Submit Expenses in Minutes Instead of at Month End",
              "description": "From receipt capture to submitted and approved claim.",
              "steps": [
                {
                  "id": "capture-the-spend",
                  "title": "Capture the spend",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "rcpt",
                      "name": "Receipt Capture and OCR",
                      "description": "Receipt extraction and evidence capture.",
                      "how": "Removes manual typing and structures the claim immediately."
                    },
                    {
                      "type": "brick",
                      "id": "mobl",
                      "name": "Mobile Expense Submission",
                      "description": "Mobile employee workflow.",
                      "how": "Lets the employee submit on the spot."
                    }
                  ]
                },
                {
                  "id": "complete-the-claim",
                  "title": "Complete the claim",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "expf",
                      "name": "Expense Form and Report Builder",
                      "description": "Expense line and report workflow.",
                      "how": "Creates a compliant report structure."
                    },
                    {
                      "type": "brick",
                      "id": "cate",
                      "name": "Spend Categorization and Tax Coding",
                      "description": "Category and coding suggestions.",
                      "how": "Reduces user uncertainty and finance cleanup."
                    }
                  ]
                },
                {
                  "id": "route-and-track",
                  "title": "Route and track",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "aprv",
                      "name": "Approval Workflow Orchestration",
                      "description": "Approval and status routing.",
                      "how": "Makes manager review and employee tracking visible."
                    }
                  ]
                }
              ]
            }
          ],
          "externalSystemsThisCapabilityDependsOn": [],
          "icon": "submit-expenses-in-minutes.png"
        }
      ]
    },
    {
      "name": "Policy and Approval Control",
      "description": "",
      "subGroups": [],
      "capabilities": [
        {
          "id": "keep-spend-in-policy",
          "name": "Keep Spend in Policy Without Finance Policing Every Claim",
          "type": "outcome-based-experience",
          "description": "Help finance and managers apply policy automatically and focus only on real exceptions.",
          "outcomes": [
            "Higher policy-compliant expense rate",
            "Lower manual review share"
          ],
          "brickDependencies": [
            {
              "targetBrickId": "poli",
              "type": "composition"
            },
            {
              "targetBrickId": "saud",
              "type": "composition"
            },
            {
              "targetBrickId": "aprv",
              "type": "composition"
            },
            {
              "targetBrickId": "budg",
              "type": "composition"
            },
            {
              "targetBrickId": "iden",
              "type": "composition"
            }
          ],
          "flows": [
            {
              "id": "policy-control-flow",
              "title": "Keep Spend in Policy Without Finance Policing Every Claim",
              "description": "From policy configuration to explainable exception handling.",
              "steps": [
                {
                  "id": "evaluate-policy",
                  "title": "Evaluate policy in real time",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "poli",
                      "name": "Policy Rules Engine",
                      "description": "Real-time policy evaluation.",
                      "how": "Checks spend and trip events before they become finance problems."
                    },
                    {
                      "type": "brick",
                      "id": "budg",
                      "name": "Budget and Cost Center Controls",
                      "description": "Budget-aware control logic.",
                      "how": "Adds team and project budget context."
                    }
                  ]
                },
                {
                  "id": "prioritize-exceptions",
                  "title": "Prioritize exceptions",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "saud",
                      "name": "Smart Audit and Risk Scoring",
                      "description": "Exception prioritization.",
                      "how": "Lets finance and managers review the smallest necessary set."
                    },
                    {
                      "type": "brick",
                      "id": "iden",
                      "name": "Identity, Roles, and Entity Access",
                      "description": "Scope and role controls.",
                      "how": "Ensures only the right approvers see the right claims."
                    }
                  ]
                },
                {
                  "id": "route-decisions",
                  "title": "Route decisions cleanly",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "aprv",
                      "name": "Approval Workflow Orchestration",
                      "description": "Approval routing.",
                      "how": "Moves decisions to the right approvers with enough context."
                    }
                  ]
                }
              ]
            }
          ],
          "externalSystemsThisCapabilityDependsOn": [],
          "icon": "keep-spend-in-policy.png"
        }
      ]
    },
    {
      "name": "Travel and Card Operations",
      "description": "",
      "subGroups": [],
      "capabilities": [
        {
          "id": "control-travel-before-cost-is-locked",
          "name": "Control Travel Before Cost Is Locked In",
          "type": "outcome-based-experience",
          "description": "Help travel managers and finance teams connect booking, approvals, and trip-related spend into one policy-aware workflow.",
          "outcomes": [
            "Higher in-policy travel booking rate",
            "Higher spend under pre-approval control"
          ],
          "brickDependencies": [
            {
              "targetBrickId": "trav",
              "type": "composition"
            },
            {
              "targetBrickId": "trip",
              "type": "composition"
            },
            {
              "targetBrickId": "tatt",
              "type": "composition"
            },
            {
              "targetBrickId": "aprv",
              "type": "composition"
            },
            {
              "targetBrickId": "duty",
              "type": "composition"
            }
          ],
          "flows": [
            {
              "id": "travel-control-flow",
              "title": "Control Travel Before Cost Is Locked In",
              "description": "From booking data ingestion to policy-aware trip approval and support.",
              "steps": [
                {
                  "id": "collect-trip-context",
                  "title": "Collect trip context",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "tatt",
                      "name": "Travel Feed and TMC Connectors",
                      "description": "Booking feed ingestion.",
                      "how": "Brings itinerary and booking data into the domain."
                    },
                    {
                      "type": "brick",
                      "id": "trav",
                      "name": "Travel Booking Hub",
                      "description": "Unified trip model.",
                      "how": "Creates one trip record used by policy and support flows."
                    }
                  ]
                },
                {
                  "id": "apply-trip-policy",
                  "title": "Apply trip policy",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "trip",
                      "name": "Trip Policy Guardrails",
                      "description": "Travel policy evaluation.",
                      "how": "Checks class, route, timing, and supplier choices."
                    },
                    {
                      "type": "brick",
                      "id": "aprv",
                      "name": "Approval Workflow Orchestration",
                      "description": "Trip approval routing.",
                      "how": "Sends costly or risky trips through the right approval path."
                    }
                  ]
                },
                {
                  "id": "support-the-trip",
                  "title": "Support the trip",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "duty",
                      "name": "Duty of Care and Trip Support",
                      "description": "Trip support operations.",
                      "how": "Improves exception handling during disruptions."
                    }
                  ]
                }
              ]
            }
          ],
          "externalSystemsThisCapabilityDependsOn": [],
          "icon": "control-travel-before-cost-is-locked.png"
        },
        {
          "id": "reconcile-card-spend-automatically",
          "name": "Reconcile Card Spend Automatically Instead of After the Fact",
          "type": "outcome-based-experience",
          "description": "Help finance and employees keep card spend tied to receipts and claims with minimal manual effort.",
          "outcomes": [
            "Higher auto-matched card transaction rate",
            "Lower manual expense review time"
          ],
          "brickDependencies": [
            {
              "targetBrickId": "card",
              "type": "composition"
            },
            {
              "targetBrickId": "crec",
              "type": "composition"
            },
            {
              "targetBrickId": "ctrl",
              "type": "composition"
            },
            {
              "targetBrickId": "rcpt",
              "type": "composition"
            }
          ],
          "flows": [
            {
              "id": "card-reconciliation-flow",
              "title": "Reconcile Card Spend Automatically Instead of After the Fact",
              "description": "From card issuance and control to receipt-linked reconciliation.",
              "steps": [
                {
                  "id": "issue-and-control-cards",
                  "title": "Issue and control cards",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "card",
                      "name": "Corporate Card Program",
                      "description": "Card issuance and program management.",
                      "how": "Creates card-backed spend visibility."
                    },
                    {
                      "type": "brick",
                      "id": "ctrl",
                      "name": "Card Controls and Limits",
                      "description": "Card restrictions and limits.",
                      "how": "Constrains card behavior before spend occurs."
                    }
                  ]
                },
                {
                  "id": "match-card-events",
                  "title": "Match card events",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "crec",
                      "name": "Card Transaction Reconciliation",
                      "description": "Card-to-receipt and card-to-claim matching.",
                      "how": "Turns raw card feeds into usable finance records."
                    },
                    {
                      "type": "brick",
                      "id": "rcpt",
                      "name": "Receipt Capture and OCR",
                      "description": "Receipt evidence capture.",
                      "how": "Supplies evidence needed to resolve card transactions."
                    }
                  ]
                }
              ]
            }
          ],
          "externalSystemsThisCapabilityDependsOn": [],
          "icon": "reconcile-card-spend-automatically.png"
        }
      ]
    },
    {
      "name": "Finance Automation and Intelligence",
      "description": "",
      "subGroups": [],
      "capabilities": [
        {
          "id": "close-the-books-faster",
          "name": "Close the Books Faster on Employee Spend",
          "type": "outcome-based-experience",
          "description": "Help finance teams reimburse employees, export clean records, and preserve audit evidence with less manual work.",
          "outcomes": [
            "Lower monthly close cycle for employee spend",
            "Higher audit-ready record completeness"
          ],
          "brickDependencies": [
            {
              "targetBrickId": "reim",
              "type": "composition"
            },
            {
              "targetBrickId": "acct",
              "type": "composition"
            },
            {
              "targetBrickId": "vatx",
              "type": "composition"
            },
            {
              "targetBrickId": "docv",
              "type": "composition"
            }
          ],
          "flows": [
            {
              "id": "finance-close-flow",
              "title": "Close the Books Faster on Employee Spend",
              "description": "From approved claim to reimbursement, accounting export, and audit evidence.",
              "steps": [
                {
                  "id": "settle-approved-claims",
                  "title": "Settle approved claims",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "reim",
                      "name": "Reimbursement Orchestration",
                      "description": "Reimbursement workflow.",
                      "how": "Turns approved claims into payable reimbursements."
                    }
                  ]
                },
                {
                  "id": "export-to-finance",
                  "title": "Export to finance",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "acct",
                      "name": "ERP and Accounting Sync",
                      "description": "Accounting export workflow.",
                      "how": "Pushes spend into ERP and accounting systems."
                    },
                    {
                      "type": "brick",
                      "id": "vatx",
                      "name": "VAT and Tax Handling",
                      "description": "Tax handling.",
                      "how": "Preserves tax-ready outputs for finance workflows."
                    }
                  ]
                },
                {
                  "id": "preserve-evidence",
                  "title": "Preserve evidence",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "docv",
                      "name": "Audit Record Vault",
                      "description": "Audit evidence storage.",
                      "how": "Keeps a traceable record for audits and investigations."
                    }
                  ]
                }
              ]
            }
          ],
          "externalSystemsThisCapabilityDependsOn": [],
          "icon": "close-the-books-faster.png"
        },
        {
          "id": "understand-and-reduce-spend-leakage",
          "name": "Understand and Reduce Spend Leakage Across the Program",
          "type": "outcome-based-experience",
          "description": "Help finance and travel leaders identify where policy leakage, supplier drift, and process drag are coming from.",
          "outcomes": [
            "Higher negotiated supplier adoption",
            "Lower manual review share"
          ],
          "brickDependencies": [
            {
              "targetBrickId": "anal",
              "type": "composition"
            },
            {
              "targetBrickId": "anom",
              "type": "composition"
            },
            {
              "targetBrickId": "inte",
              "type": "composition"
            }
          ],
          "flows": [
            {
              "id": "spend-intelligence-flow",
              "title": "Understand and Reduce Spend Leakage Across the Program",
              "description": "From normalized domain data to actionable leakage signals and dashboards.",
              "steps": [
                {
                  "id": "normalize-domain-data",
                  "title": "Normalize domain data",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "inte",
                      "name": "Integration Hub",
                      "description": "Data normalization and movement.",
                      "how": "Creates a shared data picture across HR, travel, ERP, and cards."
                    }
                  ]
                },
                {
                  "id": "surface-insight",
                  "title": "Surface insight",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "anal",
                      "name": "Spend Analytics and Benchmarking",
                      "description": "Analytical reporting.",
                      "how": "Makes spend, policy, and supplier behavior visible."
                    },
                    {
                      "type": "brick",
                      "id": "anom",
                      "name": "Anomaly and Leakage Detection",
                      "description": "Leakage signals.",
                      "how": "Flags the patterns most worth acting on."
                    }
                  ]
                }
              ]
            }
          ],
          "externalSystemsThisCapabilityDependsOn": [],
          "icon": "understand-and-reduce-spend-leakage.png"
        },
        {
          "id": "extend-into-ap-adjacency",
          "name": "Extend Spend Operations into AP Adjacency",
          "type": "outcome-based-experience",
          "description": "Give finance teams a path from employee spend workflows into supplier invoice automation and approval.",
          "outcomes": [
            "Higher finance automation suite adoption",
            "Broader controller workflow penetration"
          ],
          "brickDependencies": [
            {
              "targetBrickId": "apin",
              "type": "composition"
            },
            {
              "targetBrickId": "apwf",
              "type": "composition"
            },
            {
              "targetBrickId": "acct",
              "type": "composition"
            }
          ],
          "flows": [
            {
              "id": "ap-adjacency-flow",
              "title": "Extend Spend Operations into AP Adjacency",
              "description": "From supplier invoice intake to finance approval and accounting export.",
              "steps": [
                {
                  "id": "ingest-invoices",
                  "title": "Ingest invoices",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "apin",
                      "name": "Supplier Invoice Intake",
                      "description": "Invoice intake workflow.",
                      "how": "Creates adjacent AP records inside the finance workflow."
                    }
                  ]
                },
                {
                  "id": "route-approvals",
                  "title": "Route invoice approvals",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "apwf",
                      "name": "Invoice Approval and AP Workflow",
                      "description": "Invoice approval routing.",
                      "how": "Extends finance control patterns into supplier-spend workflows."
                    }
                  ]
                },
                {
                  "id": "export-ap-outcomes",
                  "title": "Export AP outcomes",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "acct",
                      "name": "ERP and Accounting Sync",
                      "description": "Accounting export.",
                      "how": "Pushes approved invoice outcomes into ERP and AP systems."
                    }
                  ]
                }
              ]
            }
          ],
          "externalSystemsThisCapabilityDependsOn": [],
          "icon": "extend-into-ap-adjacency.png"
        }
      ]
    }
  ]
}
