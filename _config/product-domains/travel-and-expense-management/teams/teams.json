{
  "orgDesign": {
    "domainId": "travel-and-expense-management",
    "domainName": "Travel and Expense Management",
    "companyProfile": "B2B travel and expense software company serving finance leaders, travel managers, employees, and approvers through expense capture, policy control, card-backed spend workflows, travel operations, and finance automation.",
    "operatingModel": "Employee experience teams own receipt capture, mobile submission, and manager approvals. Control teams own policy, smart audit, budgets, and card reconciliation quality. Travel and card teams own booking feeds, trip policy, support, and card controls. Finance automation teams own reimbursements, accounting sync, analytics, and integrations.",
    "designPrinciples": [
      "Keep mobile submission and receipt capture in one learning loop.",
      "Keep policy, audit, and card reconciliation tightly connected because finance judges the combined control outcome.",
      "Keep travel feed ingestion and trip policy together because pre-trip control only works when booking data arrives early."
    ],
    "staffingPrinciple": "Prefer teams of roughly 6-9 FTE with explicit customer and brick ownership.",
    "groupingPrinciple": "Use top-level groups for employee spend experience, policy and controls, travel and cards, and finance automation and data.",
    "groupLeadershipPrinciple": "Use cross-group leadership around submission compliance, policy automation, and finance-close trust."
  },
