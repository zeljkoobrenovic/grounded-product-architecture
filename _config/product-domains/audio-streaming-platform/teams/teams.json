  "orgDesign": {
    "domainId": "audio-streaming-platform",
    "domainName": "Audio Streaming Platform",
    "companyProfile": "Global audio platform centered on listener engagement, creator growth, advertising monetization, and rights-aware platform operations.",
    "operatingModel": "Listener-facing teams own discovery, playback, retention, and Premium conversion. Creator-facing teams own artist and creator growth systems. Advertising and revenue teams own monetization. Shared platform teams own identity, catalog, rights, trust, and intelligence.",
    "designPrinciples": [
      "Keep personalization, playback, and subscription value in one operating system because listener growth is cumulative.",
      "Give creators explicit product teams for growth and monetization rather than treating them as support stakeholders.",
      "Keep billing, rights, and trust close to platform foundations because errors there cascade into every business loop."
    ],
    "staffingPrinciple": "Prefer teams of roughly 8-10 FTE with explicit customer or capability ownership.",
    "groupingPrinciple": "Use top-level groups for listener growth, creator growth, advertising revenue, and shared foundations.",
    "groupLeadershipPrinciple": "Use lightweight leadership across groups tied to shared platform and monetization metrics."
