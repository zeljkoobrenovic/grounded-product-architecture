  "orgDesign": {
    "domainId": "hosted-stays-marketplace",
    "domainName": "Hosted Stays Marketplace",
    "companyProfile": "Global hosted-stays marketplace centered on guest demand, host supply, professional operations, trust, payments, and compliance.",
    "operatingModel": "Guest-facing teams own discovery, booking, and trip confidence. Host-facing teams own activation, listing quality, pricing, and portfolio operations. Shared trust, payment, compliance, and intelligence teams provide marketplace control functions.",
    "designPrinciples": [
      "Keep guest trust and host quality inside the same operating system because both sides affect marketplace conversion.",
      "Treat AirCover, payments, support, and compliance as shared platform capabilities with dedicated ownership.",
      "Separate everyday host simplicity from professional operator depth while preserving one marketplace core."
    ],
    "staffingPrinciple": "Prefer teams of roughly 8-10 FTE with explicit customer or capability ownership.",
    "groupingPrinciple": "Use top-level groups for guest marketplace, host growth, professional supply operations, and marketplace foundations.",
    "groupLeadershipPrinciple": "Use lightweight leadership across groups that share common marketplace metrics."
  },
