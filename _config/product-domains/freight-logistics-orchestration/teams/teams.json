{
  "orgDesign": {
    "domainId": "freight-logistics-orchestration",
    "domainName": "Freight Logistics Orchestration",
    "companyProfile": "Technology-enabled freight brokerage, managed transportation, carrier marketplace, TMS, contract logistics, and operations platform.",
    "operatingModel": "Shipper teams own planning, procurement, TMS, self-service, and customer integrations. Capacity teams own carrier onboarding, load offers, matching, pricing, and carrier quality. Execution teams own visibility, appointments, documents, control tower, exceptions, and automation. Foundation teams own settlement, risk, financial rules, data, analytics, experimentation, and sustainability.",
    "designPrinciples": [
      "Keep shipper service, carrier acceptance, and operations productivity connected because freight reliability is a multi-sided outcome.",
      "Separate capacity marketplace pricing from shipper planning so margin and service tradeoffs remain explicit.",
      "Treat settlement, risk, and data as shared platform capabilities with strict ownership and auditability."
    ],
    "staffingPrinciple": "Prefer teams of roughly 8-10 FTE with explicit product brick ownership.",
    "groupingPrinciple": "Use top-level groups for shipper control tower, capacity marketplace, execution visibility, and financial/intelligence foundations.",
    "groupLeadershipPrinciple": "Use lightweight group leadership around shared metrics such as on-time pickup and delivery, tender acceptance, repeat carrier acceptance, cost to serve, and clean invoice rate."
