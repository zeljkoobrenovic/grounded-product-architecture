{
  "metadata": {
    "title": "Product Capabilities",
    "description": "Outcome-based product capabilities for the Bike Mobility domain, linking customer and business outcomes to reusable product bricks and required external systems.",
    "definitions": {
      "productCapability": "A high-level, outcome-based ability that delivers customer or business value.",
      "productBrick": "A reusable implementation-facing building block used to realize one or more product capabilities."
    },
    "sources": [
      "https://staff.derbyshire.gov.uk/pay-and-benefits/my-benefits-and-discounts/cycle-to-work-scheme/cycle-to-work-scheme.aspx"
    ]
  },
  "capabilities": [
    {
      "id": "employer-launch-bike-benefit-program",
      "group": "Employer Experience",
      "name": "Launch a Bike Benefit Program",
      "type": "outcome-based-capability",
      "description": "Help an employer mobility manager set up a bike benefit program with the right policies, subsidy rules, and rollout controls.",
      "outcomes": [
        "Employers can launch programs faster",
        "Policy setup feels controlled instead of bespoke"
      ],
      "brickDependencies": [
        {
          "targetBrickId": "eppm",
          "type": "composition"
        },
        {
          "targetBrickId": "qsco",
          "type": "composition"
        },
        {
          "targetBrickId": "wfcm",
          "type": "composition"
        }
      ],
      "externalSystemsThisCapabilityDependsOn": [
        {
          "system": "HRIS and Payroll Platforms",
          "type": "system-of-record",
          "interface": "HRIS and payroll APIs",
          "description": "Provide employee, contract, and payroll context."
        }
      ],
      "flows": [
        "Create employer program",
        "Configure policy rules",
        "Simulate subsidy options",
        "Approve rollout setup"
      ]
    },
    {
      "id": "employer-keep-program-and-payroll-in-sync",
      "group": "Employer Experience",
      "name": "Keep Program and Payroll in Sync",
      "type": "outcome-based-capability",
      "description": "Help employers keep eligibility, payroll deduction, and settlement outcomes aligned across employee lifecycle events.",
      "outcomes": [
        "Fewer payroll mismatches",
        "Less manual reconciliation for employer admins"
      ],
      "brickDependencies": [
        {
          "targetBrickId": "elpy",
          "type": "composition"
        },
        {
          "targetBrickId": "sein",
          "type": "composition"
        }
      ],
      "externalSystemsThisCapabilityDependsOn": [
        {
          "system": "HRIS and Payroll Platforms",
          "type": "system-of-record",
          "interface": "File exchange and APIs",
          "description": "Provide employment and payroll execution data."
        }
      ],
      "flows": [
        "Review employee eligibility",
        "Sync payroll deductions",
        "Handle employment changes",
        "Reconcile settlement state"
      ]
    },
    {
      "id": "rider-find-right-bike",
      "group": "Rider Experience",
      "name": "Find the Right Bike",
      "type": "outcome-based-capability",
      "description": "Help a rider discover the right bike and package for their needs, employer policy, and budget.",
      "outcomes": [
        "Riders find relevant options faster",
        "Selection feels informed rather than overwhelming"
      ],
      "brickDependencies": [
        {
          "targetBrickId": "cata",
          "type": "composition"
        },
        {
          "targetBrickId": "qsco",
          "type": "composition"
        }
      ],
      "externalSystemsThisCapabilityDependsOn": [],
      "flows": [
        "Browse bike catalog",
        "Compare bike options",
        "Check eligibility impact",
        "Review savings estimate"
      ]
    },
    {
      "id": "rider-complete-order-confidently",
      "group": "Rider Experience",
      "name": "Complete an Order Confidently",
      "type": "outcome-based-capability",
      "description": "Help a rider move from selection to compliant order completion with clear status, identity, and notifications.",
      "outcomes": [
        "Lower order abandonment",
        "More transparent rider journey after submission"
      ],
      "brickDependencies": [
        {
          "targetBrickId": "orde",
          "type": "composition"
        },
        {
          "targetBrickId": "ride",
          "type": "composition"
        },
        {
          "targetBrickId": "cmns",
          "type": "composition"
        }
      ],
      "externalSystemsThisCapabilityDependsOn": [
        {
          "system": "Identity and eSignature Providers",
          "type": "trust-service",
          "interface": "Authentication and signing APIs",
          "description": "Support secure access and agreement completion."
        }
      ],
      "flows": [
        "Sign in and verify identity",
        "Reserve selected bike",
        "Submit compliant order",
        "Track post-order updates"
      ]
    },
    {
      "id": "partner-accept-and-fulfil-bike-orders",
      "group": "Dealer and Service Partner Experience",
      "name": "Accept and Fulfil Bike Orders",
      "type": "outcome-based-capability",
      "description": "Help dealers and service partners receive, plan, and fulfil handovers and servicing work with less friction.",
      "outcomes": [
        "Partners see clearer fulfillment status",
        "Handover reliability improves"
      ],
      "brickDependencies": [
        {
          "targetBrickId": "dnet",
          "type": "composition"
        },
        {
          "targetBrickId": "stav",
          "type": "composition"
        },
        {
          "targetBrickId": "scmo",
          "type": "composition"
        }
      ],
      "externalSystemsThisCapabilityDependsOn": [
        {
          "system": "Dealer and Workshop Systems",
          "type": "partner-platform",
          "interface": "Partner APIs and portals",
          "description": "Provide inventory, booking, and service status signals."
        }
      ],
      "flows": [
        "Receive partner order work",
        "Plan stock and handover",
        "Confirm fulfilment readiness",
        "Update fulfilment status"
      ]
    },
    {
      "id": "partner-handle-claims-and-service-cases",
      "group": "Dealer and Service Partner Experience",
      "name": "Handle Claims and Service Cases",
      "type": "outcome-based-capability",
      "description": "Help partners and operators resolve maintenance and insurance events without losing customer context.",
      "outcomes": [
        "Faster case resolution",
        "Better visibility across service and claims steps"
      ],
      "brickDependencies": [
        {
          "targetBrickId": "scmo",
          "type": "composition"
        },
        {
          "targetBrickId": "insc",
          "type": "composition"
        },
        {
          "targetBrickId": "intg",
          "type": "composition"
        }
      ],
      "externalSystemsThisCapabilityDependsOn": [
        {
          "system": "Insurance and Service Platforms",
          "type": "partner-platform",
          "interface": "Claims and service APIs",
          "description": "Provide external claim and repair workflow data."
        }
      ],
      "flows": [
        "Open service case",
        "Assess claim context",
        "Coordinate repair action",
        "Close service outcome"
      ]
    },
    {
      "id": "operator-manage-lease-and-risk-lifecycle",
      "group": "Operations Experience",
      "name": "Manage Lease and Risk Lifecycle",
      "type": "outcome-based-capability",
      "description": "Help operators create, control, and service lease contracts with the right risk and compliance guardrails.",
      "outcomes": [
        "Lease setup is more predictable",
        "Operators can resolve risk issues faster"
      ],
      "brickDependencies": [
        {
          "targetBrickId": "leor",
          "type": "composition"
        },
        {
          "targetBrickId": "cont",
          "type": "composition"
        },
        {
          "targetBrickId": "cpco",
          "type": "composition"
        }
      ],
      "externalSystemsThisCapabilityDependsOn": [
        {
          "system": "Credit, Insurance, and Finance Partners",
          "type": "regulated-partner",
          "interface": "Decisioning and claims APIs",
          "description": "Provide risk and financing services."
        }
      ],
      "flows": [
        "Create lease case",
        "Run risk decision",
        "Approve contract setup",
        "Handle lifecycle exceptions"
      ]
    },
    {
      "id": "operator-recover-value-from-returned-bikes",
      "group": "Operations Experience",
      "name": "Recover Value from Returned Bikes",
      "type": "outcome-based-capability",
      "description": "Help operators track pooled or returned bikes, decide next-best action, and maximize reuse or resale value.",
      "outcomes": [
        "Higher residual-value recovery",
        "Better operational visibility over bike assets"
      ],
      "brickDependencies": [
        {
          "targetBrickId": "pbfm",
          "type": "composition"
        },
        {
          "targetBrickId": "trkm",
          "type": "composition"
        },
        {
          "targetBrickId": "rema",
          "type": "composition"
        }
      ],
      "externalSystemsThisCapabilityDependsOn": [],
      "flows": [
        "Track returned bikes",
        "Assess next-best action",
        "Route to fleet or resale",
        "Monitor recovery value"
      ]
    }
  ]
}
