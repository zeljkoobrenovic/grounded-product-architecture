            }
          ],
          "flows": [
            {
              "id": "run-trust-and-finance-operations-flow",
              "title": "Run Trust, Reporting, and Finance Operations",
              "description": "From real-time decisions into auditable reporting and integrations.",
              "steps": [
                {
                  "id": "make-real-time-risk-and-state-decisions",
                  "title": "Make real-time risk and state decisions",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "rada",
                      "name": "Fraud Detection and Adaptive Risk Controls",
                      "description": "Real-time risk decisioning.",
                      "how": "Protects the system while preserving legitimate activity."
                    },
                    {
                      "type": "brick",
                      "id": "ledg",
                      "name": "Balances and Internal Ledger",
                      "description": "Financial state tracking.",
                      "how": "Provides the source of truth for money-state transitions."
                    }
                  ]
                },
                {
                  "id": "understand-and-resolve-exceptions",
                  "title": "Understand and resolve exceptions",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "disp",
                      "name": "Disputes and Chargeback Operations",
                      "description": "Dispute workflows.",
                      "how": "Explains and manages post-transaction risk events."
                    },
                    {
                      "type": "brick",
                      "id": "reca",
                      "name": "Reconciliation and Balance Operations",
                      "description": "Finance exception workflow.",
                      "how": "Helps operators close the loop on money movement anomalies."
                    }
