{
  "metadata": {
    "title": "Product Experiences",
    "description": "Outcome-based product experiences for the Payments and Revenue Infrastructure domain, covering payments, recurring monetization, platform money movement, and shared financial operations.",
    "definitions": {
      "productBrick": "A reusable implementation-facing building block used to realize one or more product experiences.",
      "productCapability": "A high-level, outcome-based experience that delivers customer or business value."
    },
    "sources": [
      "https://stripe.com/payments",
      "https://stripe.com/payments/elements",
      "https://stripe.com/billing",
      "https://stripe.com/connect",
      "https://stripe.com/terminal",
      "https://stripe.com/radar",
      "https://docs.stripe.com/tax/dashboard",
      "https://stripe.com/identity"
    ],
    "flowModelVersion": "3.2",
    "flowModelNote": "Each experience carries only experience-specific flows. Each flow step lists the bricks and external systems used inside that experience."
  },
  "rootGroups": [
    {
      "name": "Merchant Payments",
      "description": "",
      "subGroups": [],
      "capabilities": [
        {
          "id": "accept-payments-globally",
          "name": "Accept Payments Globally with High Conversion",
          "type": "outcome-based-experience",
          "description": "Help merchants turn purchase intent into captured payments across markets and payment methods with low friction and low loss.",
          "outcomes": [
            "Higher successful payment conversion",
            "Higher merchant GPV retention"
          ],
          "brickDependencies": [
            {
              "targetBrickId": "chck",
              "type": "composition"
            },
            {
              "targetBrickId": "elem",
              "type": "composition"
            },
            {
              "targetBrickId": "pmtd",
              "type": "composition"
            },
            {
              "targetBrickId": "auth",
              "type": "composition"
            },
            {
              "targetBrickId": "rada",
              "type": "composition"
            },
            {
              "targetBrickId": "disp",
              "type": "composition"
            }
          ],
          "flows": [
            {
              "id": "accept-payments-globally-flow",
              "title": "Accept Payments Globally with High Conversion",
              "description": "From buyer checkout intent to captured payment and managed exceptions.",
              "steps": [
                {
                  "id": "launch-the-right-checkout-surface",
                  "title": "Launch the right checkout surface",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "chck",
                      "name": "Hosted Checkout",
                      "description": "Hosted checkout experience.",
                      "how": "Accelerates launch and standardizes buyer experience."
                    },
                    {
                      "type": "brick",
                      "id": "elem",
                      "name": "Payment Elements",
                      "description": "Embeddable payment UI.",
                      "how": "Supports custom payment experiences without rebuilding orchestration."
                    }
                  ]
                },
                {
                  "id": "present-the-best-payment-options",
                  "title": "Present the best payment options",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "pmtd",
                      "name": "Payment Method Orchestration",
                      "description": "Payment method selection and ordering.",
                      "how": "Shows the right methods by market and context."
                    },
                    {
                      "type": "brick",
                      "id": "auth",
                      "name": "Authorization Optimization",
                      "description": "Approval-rate optimization.",
                      "how": "Recovers legitimate payments that would otherwise fail."
                    }
                  ]
                },
                {
                  "id": "protect-and-operate-the-transaction",
                  "title": "Protect and operate the transaction",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "rada",
                      "name": "Fraud Detection and Adaptive Risk Controls",
                      "description": "Fraud scoring and adaptive controls.",
                      "how": "Reduces fraud without unnecessary conversion loss."
                    },
                    {
                      "type": "brick",
                      "id": "disp",
                      "name": "Disputes and Chargeback Operations",
                      "description": "Post-payment loss and dispute handling.",
                      "how": "Keeps payment success economically durable."
                    }
                  ]
                }
              ]
            }
          ],
          "externalSystemsThisCapabilityDependsOn": []
        }
      ]
    },
    {
      "name": "Revenue Automation",
      "description": "",
      "subGroups": [],
      "capabilities": [
        {
          "id": "automate-recurring-revenue",
          "name": "Automate Recurring Revenue and Finance Workflows",
          "type": "outcome-based-experience",
          "description": "Help recurring businesses launch monetization changes quickly while keeping collections, tax, and accounting trustworthy.",
          "outcomes": [
            "Higher net revenue retention",
            "Lower month-end manual work"
          ],
          "brickDependencies": [
            {
              "targetBrickId": "subs",
              "type": "composition"
            },
            {
              "targetBrickId": "usag",
              "type": "composition"
            },
            {
              "targetBrickId": "invo",
              "type": "composition"
            },
            {
              "targetBrickId": "taxx",
              "type": "composition"
            },
            {
              "targetBrickId": "revn",
              "type": "composition"
            },
            {
              "targetBrickId": "rpts",
              "type": "composition"
            }
          ],
          "flows": [
            {
              "id": "automate-recurring-revenue-flow",
              "title": "Automate Recurring Revenue and Finance Workflows",
              "description": "From pricing setup to collections and accounting outputs.",
              "steps": [
                {
                  "id": "configure-monetization",
                  "title": "Configure monetization",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "subs",
                      "name": "Subscription and Price Management",
                      "description": "Recurring pricing and lifecycle logic.",
                      "how": "Lets RevOps launch recurring models quickly."
                    },
                    {
                      "type": "brick",
                      "id": "usag",
                      "name": "Usage Metering and Rating",
                      "description": "Usage billing logic.",
                      "how": "Supports modern hybrid and usage-based models."
                    }
                  ]
                },
                {
                  "id": "collect-and-recover-revenue",
                  "title": "Collect and recover revenue",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "invo",
                      "name": "Invoicing and Collections",
                      "description": "Invoice and dunning workflow.",
                      "how": "Turns billable activity into collected cash."
                    },
                    {
                      "type": "brick",
                      "id": "auth",
                      "name": "Authorization Optimization",
                      "description": "Recurring payment optimization.",
                      "how": "Improves renewal success on legitimate charges."
                    }
                  ]
                },
                {
                  "id": "close-the-loop-with-finance",
                  "title": "Close the loop with finance",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "taxx",
                      "name": "Tax Determination and Registration",
                      "description": "Tax compliance operations.",
                      "how": "Keeps monetization globally launchable."
                    },
                    {
                      "type": "brick",
                      "id": "revn",
                      "name": "Revenue Recognition",
                      "description": "Accounting treatment automation.",
                      "how": "Makes billed activity auditable and trusted."
                    },
                    {
                      "type": "brick",
                      "id": "rpts",
                      "name": "Reporting, Sigma, and Data Export",
                      "description": "Reporting and exports.",
                      "how": "Gives RevOps and finance one analytical picture."
                    }
                  ]
                }
              ]
            }
          ],
          "externalSystemsThisCapabilityDependsOn": []
        }
      ]
    },
    {
      "name": "Platform Infrastructure",
      "description": "",
      "subGroups": [],
      "capabilities": [
        {
          "id": "operate-platform-money-movement",
          "name": "Operate Platform Onboarding, Funds Flows, and Payouts",
          "type": "outcome-based-experience",
          "description": "Help platforms activate counterparties, route funds, and scale payouts safely with strong operator visibility.",
          "outcomes": [
            "Higher connected-account activation",
            "Higher platform GPV growth"
          ],
          "brickDependencies": [
            {
              "targetBrickId": "acct",
              "type": "composition"
            },
            {
              "targetBrickId": "kycb",
              "type": "composition"
            },
            {
              "targetBrickId": "iden",
              "type": "composition"
            },
            {
              "targetBrickId": "split",
              "type": "composition"
            },
            {
              "targetBrickId": "pyot",
              "type": "composition"
            },
            {
              "targetBrickId": "reca",
              "type": "composition"
            }
          ],
          "flows": [
            {
              "id": "operate-platform-money-movement-flow",
              "title": "Operate Platform Onboarding, Funds Flows, and Payouts",
              "description": "From connected-account onboarding into live payouts and operator controls.",
              "steps": [
                {
                  "id": "activate-connected-accounts",
                  "title": "Activate connected accounts",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "acct",
                      "name": "Connected Account Lifecycle",
                      "description": "Connected-account state model.",
                      "how": "Keeps account activation and capability state explicit."
                    },
                    {
                      "type": "brick",
                      "id": "kycb",
                      "name": "KYC and KYB Verification",
                      "description": "Verification workflows.",
                      "how": "Reduces activation loss caused by incomplete compliance steps."
                    },
                    {
                      "type": "brick",
                      "id": "iden",
                      "name": "Identity Verification",
                      "description": "Higher-assurance identity workflows.",
                      "how": "Adds trust where platforms need stronger assurance."
                    }
                  ]
                },
                {
                  "id": "route-and-disburse-funds",
                  "title": "Route and disburse funds",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "split",
                      "name": "Funds Routing and Split Settlement",
                      "description": "Funds-flow orchestration.",
                      "how": "Handles fees, reserves, and multi-party settlement."
                    },
                    {
                      "type": "brick",
                      "id": "pyot",
                      "name": "Global Payouts and Treasury Workflows",
                      "description": "Payout execution.",
                      "how": "Moves money out on the right schedule and rails."
                    }
                  ]
                },
                {
                  "id": "operate-the-money-system",
                  "title": "Operate the money system",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "ledg",
                      "name": "Balances and Internal Ledger",
                      "description": "Shared money-state ledger.",
                      "how": "Keeps ownership of money legible across parties."
                    },
                    {
                      "type": "brick",
                      "id": "reca",
                      "name": "Reconciliation and Balance Operations",
                      "description": "Exception and payout operations.",
                      "how": "Lets platform operators trust what happened and why."
                    }
                  ]
                }
              ]
            }
          ],
          "externalSystemsThisCapabilityDependsOn": []
        }
      ]
    },
