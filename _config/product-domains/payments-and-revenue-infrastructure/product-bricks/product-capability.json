                    {
                      "type": "brick",
                      "id": "webh",
                      "name": "Eventing and Webhooks",
                      "description": "Event-driven integration layer.",
                      "how": "Connects Stripe state changes to customer systems."
                    },
                    {
                      "type": "brick",
                      "id": "devx",
                      "name": "Developer API and Dashboard Foundations",
                      "description": "Shared control plane.",
                      "how": "Makes the domain programmable and operable."
