{
  "orgDesign": {
    "domainId": "payments-and-revenue-infrastructure",
    "domainName": "Payments and Revenue Infrastructure",
    "companyProfile": "Programmable financial infrastructure company serving merchants, recurring-revenue businesses, and platforms through payments, billing, connect, risk, and finance operations products.",
    "operatingModel": "Payments teams own checkout, payment methods, and authorization loops. Revenue automation teams own pricing, usage billing, tax, and accounting outputs. Connect teams own onboarding, funds routing, and payouts. Shared trust and platform teams own fraud, ledgering, reconciliation, APIs, and reporting.",
    "designPrinciples": [
      "Keep checkout UX, payment methods, and authorization optimization in one learning loop.",
      "Keep billing, tax, recognition, and reporting together because monetization trust breaks when these workflows diverge.",
      "Keep onboarding, funds routing, and payouts tightly connected because platforms judge the full money-movement loop."
    ],
    "staffingPrinciple": "Prefer teams of roughly 7-10 FTE with explicit customer or product-brick ownership.",
    "groupingPrinciple": "Use top-level groups for payments experience, revenue automation, connect and money movement, trust and finance operations, and developer platform.",
    "groupLeadershipPrinciple": "Use cross-group leadership around payment conversion, recurring-revenue expansion, and platform money-movement quality."
  },
