  "orgDesign": {
    "domainId": "ride-sharing-marketplace",
    "domainName": "Ride Sharing Marketplace",
    "companyProfile": "Global ride-sharing marketplace business combining rider demand, driver and fleet supply, business travel programs, safety operations, and shared marketplace-control platforms.",
    "operatingModel": "Customer-facing teams own rider, driver, fleet, and business outcomes while shared marketplace teams own dispatch, pricing, trust, and analytics reused across every product surface.",
    "designPrinciples": [
      "Keep rider, driver, and business loops explicit because their economics and workflow tradeoffs differ materially.",
      "Treat dispatch, pricing, and trust as core control functions rather than support services.",
      "Use fleet and business teams to deepen higher-value supply and demand without fragmenting the core marketplace."
    ],
    "staffingPrinciple": "Prefer teams of roughly 8-11 FTE with clear ownership of a customer loop or reusable capability.",
    "groupingPrinciple": "Use top-level groups for rider, supply, trust, business, and shared marketplace foundations.",
    "groupLeadershipPrinciple": "Use lightweight group leadership where multiple teams share a tight economic or operational loop."
  },
