      "brickDependencies": [
        {
          "targetBrickId": "ords",
          "type": "composition"
        },
        {
          "targetBrickId": "idpr",
          "type": "composition"
        }
      ],
      "externalSystemsThisCapabilityDependsOn": [
        {
          "system": "Payment and Travel Document Systems",
          "type": "airline-ecosystem",
          "interface": "Payment and document interfaces",
          "description": "Provide payment and fulfillment dependencies."
        }
      ],
      "flows": [
        "Open booking",
        "Change itinerary or service",
        "Review document readiness",
        "Confirm booking update"
      ]
    },
