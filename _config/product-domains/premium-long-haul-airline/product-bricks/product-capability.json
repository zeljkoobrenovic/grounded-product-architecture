{
  "metadata": {
    "title": "Product Capabilities",
    "description": "Outcome-based product capabilities for the Premium Long-Haul Airline domain, grounded in airline retailing, servicing, operations, and partner connectivity.",
    "definitions": {
      "productCapability": "A high-level, outcome-based ability that delivers customer or business value.",
      "productBrick": "A reusable implementation-facing building block used to realize one or more product capabilities."
    },
    "sources": [
      "https://www.iata.org/en/programs/airline-distribution/ndc/",
      "https://www.iata.org/en/programs/airline-distribution/one-order/"
    ]
  },
  "capabilities": [
    {
      "id": "traveler-find-and-compare-the-right-trip",
      "group": "Retail Traveler Experience",
      "name": "Find and Compare the Right Trip",
      "type": "outcome-based-capability",
      "description": "Help a traveler understand the best offer, itinerary, and premium options before booking.",
      "outcomes": [
        "Higher retail conversion",
        "Better offer clarity"
      ],
      "brickDependencies": [
        {
          "targetBrickId": "ofav",
          "type": "composition"
        },
        {
          "targetBrickId": "ancm",
          "type": "composition"
        }
      ],
      "externalSystemsThisCapabilityDependsOn": [
        {
          "system": "GDS and Distribution Channels",
          "type": "airline-ecosystem",
          "interface": "Distribution interfaces",
          "description": "Provide indirect retailing connectivity."
        }
      ],
      "flows": [
        "Search trip options",
        "Compare offers",
        "Review premium add-ons",
        "Choose preferred itinerary"
      ]
    },
    {
      "id": "traveler-manage-a-booking-after-purchase",
      "group": "Retail Traveler Experience",
      "name": "Manage a Booking After Purchase",
      "type": "outcome-based-capability",
      "description": "Help travelers change, service, and complete order-related tasks after booking.",
      "outcomes": [
        "Lower servicing friction",
        "Better post-booking flexibility"
