  "orgDesign": {
    "domainId": "premium-long-haul-airline",
    "domainName": "Premium Long-Haul Airline",
    "companyProfile": "Premium long-haul airline and travel company operating passenger retail, loyalty, holidays, partner connectivity, disruption-heavy airport operations, and cargo. The domain is modeled as focused teams of roughly 8-11 FTE plus lightweight group leadership.",
    "operatingModel": "Value-stream teams own guest, holiday, commercial, operations, and cargo outcomes while shared platform teams provide identity, payments, integration, data, and reliability capabilities reused across the portfolio.",
    "designPrinciples": [
      "Separate guest retail, holidays, commercial distribution, operations recovery, and cargo because they have distinct customers, workflows, and economics.",
      "Keep customer care and disruption recovery tightly linked to operations rather than hiding them in a generic support function.",
      "Use shared platform teams only where reuse is structurally high: identity, payments, eventing, data, and resilience."
    ],
    "staffingPrinciple": "Prefer teams of roughly 8-11 FTE with explicit KPI ownership and a narrow enough scope to keep discovery and delivery fast.",
    "groupingPrinciple": "Use top-level groups for distinct value streams and keep most groups to one or two teams.",
    "groupLeadershipPrinciple": "Add lightweight group-level leadership and principal IC coverage across larger streams instead of oversizing any single team."
  },
