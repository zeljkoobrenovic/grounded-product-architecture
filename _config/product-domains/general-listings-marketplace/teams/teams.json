{
  "orgDesign": {
    "domainId": "general-listings-marketplace",
    "domainName": "General Listings Marketplace",
    "companyProfile": "Typical mid-size local classifieds marketplace with broad category coverage, high casual-seller volume, a meaningful professional merchant business, and shared trust and platform services.",
    "operatingModel": "Customer-facing teams own buyer, seller, merchant, and trust journeys, while platform and intelligence teams provide reusable search, data, identity, and transaction foundations.",
    "designPrinciples": [
      "Separate buyer, casual seller, and professional seller loops because their optimization levers differ materially.",
      "Treat trust, identity, and protected transactions as a shared marketplace control function.",
      "Keep market intelligence and pricing close to discovery, listing quality, and monetization decisions."
    ],
    "staffingPrinciple": "Prefer teams of roughly 8-11 FTE with clear journey or capability ownership.",
    "groupingPrinciple": "Use top-level groups for major marketplace value streams and keep a small number of teams per stream.",
    "groupLeadershipPrinciple": "Add lightweight group leadership only where multiple teams share a tight operating loop."
  },
