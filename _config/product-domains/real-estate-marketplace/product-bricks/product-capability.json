        {
          "targetBrickId": "nose",
          "type": "composition"
        }
      ],
      "externalSystemsThisCapabilityDependsOn": [
        {
          "system": "Search and Messaging Services",
          "type": "platform-service",
          "interface": "Search and notification APIs",
          "description": "Support discovery indexing and alert delivery."
        }
      ],
      "flows": [
        "Search homes",
        "Apply location and attribute filters",
        "Save search",
        "Return from alert"
      ]
    },
