{
  "metadata": {
    "title": "Product Capabilities",
    "description": "Outcome-based product capabilities for the Real Estate Marketplace domain, covering discovery, owner enablement, agency operations, market intelligence, and trust services.",
    "definitions": {
      "productCapability": "A high-level, outcome-based ability that delivers customer or business value.",
      "productBrick": "A reusable implementation-facing building block used to realize one or more product capabilities."
    },
    "sources": [
      "https://www.zillow.com/agent-resources/agent-toolkit/zillow-offers-toolkit/"
    ]
  },
  "capabilities": [
    {
      "id": "seeker-discover-relevant-homes",
      "group": "Seeker Journey",
      "name": "Discover Relevant Homes",
      "type": "outcome-based-capability",
      "description": "Help property seekers enter the marketplace and immediately see relevant homes.",
      "outcomes": [
        "Higher discovery engagement",
        "Better personalized exploration"
      ],
      "brickDependencies": [
        {
          "targetBrickId": "home",
          "type": "composition"
        },
        {
          "targetBrickId": "ubws",
          "type": "composition"
        }
      ],
      "externalSystemsThisCapabilityDependsOn": [],
      "flows": [
        "Open home feed",
        "Browse featured properties",
        "See personalized recommendations",
        "Open a promising home"
      ]
    },
    {
      "id": "seeker-search-save-and-return",
      "group": "Seeker Journey",
      "name": "Search, Save, and Return",
      "type": "outcome-based-capability",
      "description": "Help seekers narrow the market, save intent, and come back to the right homes later.",
      "outcomes": [
        "Higher return visits",
        "Faster route back to relevant homes"
