{
  "metadata": {
    "title": "Product Experiences",
    "description": "Outcome-based product experiences for the Enterprise CRM and Revenue Operations domain, refactored using the Salesforce capability decomposition from temp-sf.",
    "definitions": {
      "productBrick": "A reusable implementation-facing building block used to realize one or more product experiences.",
      "productCapability": "A high-level, outcome-based experience that delivers customer or business value."
    },
    "sources": [
      "https://www.salesforce.com/sales/cloud/",
      "https://www.salesforce.com/products/service-cloud/overview/",
      "https://www.salesforce.com/agentforce/how-it-works/",
      "https://www.salesforce.com/news/linked-content/what-is-data-cloud/datacloud_explainer/",
      "../../_config/_prompts/temp-sf/capabilities.csv"
    ],
    "flowModelVersion": "3.2",
    "flowModelNote": "Each experience carries only experience-specific flows. Each flow step lists the bricks and external systems used inside that experience."
  },
  "rootGroups": [
