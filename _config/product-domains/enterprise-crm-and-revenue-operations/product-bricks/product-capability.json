      "name": "Lead, Account, and Opportunity Operations",
      "description": "",
      "subGroups": [],
      "capabilities": [
        {
          "id": "unify-accounts-contacts-and-opportunities",
          "name": "Unify Accounts, Contacts, and Opportunities",
          "type": "outcome-based-experience",
          "description": "Give revenue teams one trusted system of record for account context, relationship structure, lead flow, and active opportunity work.",
          "outcomes": [
            "Cleaner pipeline entry",
            "More trusted account context"
          ],
          "brickDependencies": [
            {
              "targetBrickId": "acct",
              "type": "composition"
            },
            {
              "targetBrickId": "rels",
              "type": "composition"
            },
            {
              "targetBrickId": "lead",
              "type": "composition"
            },
            {
              "targetBrickId": "oppo",
              "type": "composition"
            }
          ],
          "flows": [
            {
              "id": "account-opportunity-foundation-flow",
              "title": "Unify Accounts, Contacts, and Opportunities",
              "description": "From account structure to active deal execution.",
              "steps": [
                {
                  "id": "build-account-context",
                  "title": "Build account context",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "acct",
                      "name": "Account Management and 360",
                      "description": "Account graph and insight model.",
                      "how": "Creates the core account and whitespace context."
                    },
                    {
                      "type": "brick",
                      "id": "rels",
                      "name": "Contact and Relationship Management",
                      "description": "Contact and relationship structure.",
                      "how": "Adds buyer, contact, and multi-account relationship context."
                    }
                  ]
                },
                {
                  "id": "qualify-demand",
                  "title": "Qualify and route demand",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "lead",
                      "name": "Lead Capture and Qualification",
                      "description": "Lead intake and scoring.",
                      "how": "Turns demand into governed opportunity entry."
                    }
                  ]
                },
                {
                  "id": "work-the-deal",
                  "title": "Work the deal",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "oppo",
                      "name": "Opportunity and Sales Console",
                      "description": "Opportunity system of record.",
                      "how": "Anchors active deal progression in one seller workspace."
                    }
                  ]
                }
              ]
            }
          ],
          "icon": "unify-accounts-contacts-and-opportunities.png"
        },
