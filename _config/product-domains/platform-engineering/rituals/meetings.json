{
  "schemaVersion": "1.0",
  "scope": "platform-engineering-domain",
  "description": "Recurring meetings for a platform-engineering organization that treats internal developers and technology teams as customers and runs the platform as an internal product portfolio.",
  "meetings": [
    {
      "id": "weekly-platform-triad",
      "title": "Platform Product Triad Sync",
      "category": "product-delivery",
      "description": "Weekly working session for each platform team lead trio to align product choices, technical tradeoffs, and customer evidence.",
      "goal": "Keep platform product decisions close to internal-customer outcomes rather than tool ownership alone.",
      "participants": {
        "required": [
          "Platform Product Manager",
          "Engineering Lead",
          "Staff Engineer"
        ],
        "optional": [
          "Designer",
          "Analyst",
          "Enablement Lead"
        ]
      },
      "owner": "Platform Product Manager",
      "cadence": "weekly",
      "durationMinutes": 60,
      "format": "decision-and-planning",
      "inputs": [
        "Team backlog",
        "Recent customer evidence",
        "Adoption and reliability signals",
        "Open technical tradeoffs"
      ],
      "outputs": [
        "Priority decisions",
        "Escalations",
        "Validated experiments",
        "Ownership updates"
      ]
    },
    {
      "id": "daily-platform-standup",
      "title": "Platform Delivery Standup",
      "category": "delivery",
      "description": "Short daily coordination across engineers and product leaders inside each platform squad.",
      "goal": "Surface blockers, handoffs, and production concerns early.",
      "participants": {
        "required": [
          "Engineers",
          "Engineering Lead",
          "Platform Product Manager"
        ],
        "optional": [
          "QA Engineer",
          "Reliability Engineer"
        ]
      },
      "owner": "Engineering Lead",
      "cadence": "daily",
      "durationMinutes": 15,
      "format": "coordination",
      "inputs": [
        "Active work items",
        "Production issues",
        "Dependency blockers"
      ],
      "outputs": [
        "Escalated blockers",
        "Daily coordination actions",
        "Revised delivery expectations"
      ]
    },
    {
      "id": "weekly-platform-customer-review",
      "title": "Platform Customer Review",
      "category": "customer-evidence",
      "description": "Review of onboarding friction, migration themes, support demand, and team feedback across the platform portfolio.",
      "goal": "Keep platform investment grounded in real customer pain rather than internal opinions about tooling.",
      "participants": {
        "required": [
          "Platform Product Managers",
          "Enablement Lead",
          "Analyst"
        ],
        "optional": [
          "Engineering Managers",
          "Staff Engineers",
          "Designers"
        ]
      },
      "owner": "Head of Platform Product",
      "cadence": "weekly",
      "durationMinutes": 60,
      "format": "evidence-review",
      "inputs": [
        "Support patterns",
        "Migration notes",
        "Usage telemetry",
        "Customer interview summaries"
      ],
      "outputs": [
        "Validated platform pain points",
        "Discovery priorities",
        "Roadmap adjustments"
      ]
    },
    {
      "id": "biweekly-runtime-governance",
      "title": "Runtime and Guardrails Review",
      "category": "operations-governance",
      "description": "Biweekly review of runtime standards, policy coverage, exceptions, and platform operational risk.",
      "goal": "Improve control coverage and reliability while keeping the standard path usable.",
      "participants": {
        "required": [
          "Identity and Guardrails Lead",
          "Observability and Reliability Lead",
          "Delivery Automation Lead"
        ],
        "optional": [
          "Security Lead",
          "Compliance Engineer",
          "Enablement Lead"
        ]
      },
      "owner": "Identity and Guardrails Lead",
      "cadence": "biweekly",
      "durationMinutes": 60,
      "format": "review-and-decision",
      "inputs": [
        "Control coverage report",
        "Exception trends",
        "Incident findings",
        "Template and pipeline changes"
      ],
      "outputs": [
        "Guardrail changes",
        "Exception policy updates",
        "Platform hardening priorities"
      ]
    },
    {
      "id": "weekly-platform-reliability",
      "title": "Platform Reliability Review",
      "category": "reliability",
      "description": "Weekly operating review of incidents, alert quality, telemetry coverage, and shared-platform recovery work.",
      "goal": "Continuously improve MTTR and reduce recurring shared-platform failure modes.",
      "participants": {
        "required": [
          "Observability and Reliability Lead",
          "Site Reliability Engineers",
          "Portal and Catalog Lead"
        ],
        "optional": [
          "Delivery Automation Lead",
          "Analyst",
          "Security Lead"
        ]
      },
      "owner": "Observability and Reliability Lead",
      "cadence": "weekly",
      "durationMinutes": 45,
      "format": "operational-review",
      "inputs": [
        "Incident timeline reviews",
        "Alert quality metrics",
        "Service ownership gaps",
        "Open reliability actions"
      ],
      "outputs": [
        "Reliability fixes",
        "Automation priorities",
        "Escalations",
        "Post-incident ownership"
      ]
    },
    {
      "id": "monthly-platform-portfolio-review",
      "title": "Platform Portfolio Review",
      "category": "portfolio",
      "description": "Monthly review of adoption, flow, cost, control coverage, and product strategy across the platform portfolio.",
      "goal": "Run platform engineering as a product portfolio with explicit investment and lifecycle choices.",
      "participants": {
        "required": [
          "Head of Platform Engineering",
          "Head of Platform Product",
          "Engineering Managers",
          "Platform Product Managers"
        ],
        "optional": [
          "Finance Partner",
          "Security Leader",
          "Enterprise Architect"
        ]
      },
      "owner": "Head of Platform Engineering",
      "cadence": "monthly",
      "durationMinutes": 90,
      "format": "portfolio-review",
      "inputs": [
        "Platform value pack",
        "Adoption trends",
        "Cost and capacity signals",
        "Reliability and control posture"
      ],
      "outputs": [
        "Investment shifts",
        "Lifecycle decisions",
        "Priority changes",
        "Cross-team commitments"
      ]
    }
  ]
}
