{
  "metadata": {
    "title": "Product Capabilities",
    "description": "Outcome-based product capabilities for the Platform Engineering domain, centered on developer self-service, runtime foundations, secure delivery, and engineering insight.",
    "definitions": {
      "productCapability": "A high-level, outcome-based ability that delivers customer or business value.",
      "productBrick": "A reusable implementation-facing building block used to realize one or more product capabilities."
    },
    "sources": [
      "https://cncf.io/blog/2024/05/22/platform-engineering-maturity-model-assessing-maturity-using-the-open-platform-maturity-model/",
      "https://backstage.io/docs/next/getting-started/viewing-catalog"
    ]
  },
  "capabilities": [
    {
      "id": "developer-find-the-right-platform-path",
      "group": "Developer Journey",
      "name": "Find the Right Platform Path",
      "type": "outcome-based-capability",
      "description": "Help developers understand which services, standards, and ownership boundaries apply to their work.",
      "outcomes": [
        "Lower cognitive load",
        "Faster orientation in the platform"
      ],
      "brickDependencies": [
        {
          "targetBrickId": "port",
          "type": "composition"
        },
        {
          "targetBrickId": "apps",
          "type": "composition"
        }
      ],
      "externalSystemsThisCapabilityDependsOn": [
