{
  "orgDesign": {
    "domainId": "local-on-demand-delivery-marketplace",
    "domainName": "Local On-Demand Delivery Marketplace",
    "companyProfile": "Multi-sided local delivery marketplace for consumers, merchants, couriers, grocery and retail partners, advertisers, and operations teams.",
    "operatingModel": "Consumer teams own discovery, ordering, membership, tracking, and support. Merchant teams own partner onboarding, catalog, operations, ads, promotions, and reporting. Courier teams own work access, dispatch, earnings, routing, and safety. Shared foundation teams own pricing, identity, risk, ledger, data, experimentation, APIs, and marketplace operations.",
    "designPrinciples": [
      "Keep consumer promise, merchant prep, and courier dispatch metrics connected because delivery quality is a three-sided outcome.",
      "Separate merchant growth tooling from marketplace pricing and ads measurement to keep commercial incentives explicit.",
      "Treat identity, risk, ledger, and data as shared platform capabilities with strict ownership."
    ],
    "staffingPrinciple": "Prefer teams of roughly 8-10 FTE with explicit product brick ownership.",
    "groupingPrinciple": "Use top-level groups for consumer marketplace, merchant and retail growth, courier logistics, and marketplace foundations.",
    "groupLeadershipPrinciple": "Use lightweight group leadership around shared marketplace metrics such as order conversion, delivery reliability, active supply, and contribution margin."
  },
