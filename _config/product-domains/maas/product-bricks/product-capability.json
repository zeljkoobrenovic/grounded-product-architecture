{
  "metadata": {
    "title": "Product Capabilities",
    "description": "Outcome-based product capabilities for the Mobility-as-a-Service domain, spanning multimodal access, payments, operator controls, and partner integration.",
    "definitions": {
      "productCapability": "A high-level, outcome-based ability that delivers customer or business value.",
      "productBrick": "A reusable implementation-facing building block used to realize one or more product capabilities."
    },
    "sources": [
      "https://maas-alliance.eu/2022/09/13/mobility-as-a-service-maas/"
    ]
  },
  "capabilities": [
    {
      "id": "driver-or-citizen-find-the-right-parking-option",
      "group": "Parking and Curb User Experience",
      "name": "Find the Right Parking Option",
      "type": "outcome-based-capability",
      "description": "Help a driver or citizen understand parking options, rules, and availability before arrival.",
      "outcomes": [
        "Lower arrival friction",
        "Better parking utilization"
      ],
      "brickDependencies": [
        {
          "targetBrickId": "pcon",
          "type": "composition"
        },
        {
          "targetBrickId": "resv",
          "type": "composition"
        },
        {
          "targetBrickId": "dypr",
          "type": "composition"
        }
      ],
      "externalSystemsThisCapabilityDependsOn": [],
      "flows": [
        "Search nearby parking",
        "Compare parking policies",
        "Review availability or reservation options",
        "Select parking choice"
      ]
    },
