{
  "orgDesign": {
    "domainId": "arrive",
    "domainName": "Arrive",
    "companyProfile": "Global urban-mobility platform business combining parking, transport payments, business mobility, city intelligence, partner ecosystem, and automotive-data services. The domain is modeled as a network of focused teams sized around 8-11 FTE.",
    "operatingModel": "Value-stream teams own parking, transit, city, fleet, and partner outcomes while platform teams provide identity, integration, ledger, workflow, data, and reliability capabilities reused across all business lines.",
    "designPrinciples": [
      "Keep parking, transit, fleet, partner, and city-planning workflows explicit because the buyers and economics are different.",
      "Centralize settlement, workflow, data, and reliability because reuse is structurally high across the portfolio.",
      "Treat partner and automotive services as product areas with clear ownership rather than commercial sidecars."
    ],
    "staffingPrinciple": "Prefer teams of roughly 8-11 FTE with narrow enough scope to keep product and delivery decisions fast.",
    "groupingPrinciple": "Use top-level groups for major value streams and a shared platform group for high-reuse technical capabilities.",
    "groupLeadershipPrinciple": "Use lightweight group leadership across larger streams instead of oversizing any single team."
  },
