  "orgDesign": {
    "domainId": "industrial-water-intelligence",
    "domainName": "Industrial Water Intelligence",
    "companyProfile": "Hybrid industrial-water organization combining software, edge connectivity, remote operations, chemistry expertise, and field service.",
    "operatingModel": "Teams own reusable digital products and service workflows while field and remote experts execute through shared operational systems. The goal is to productize repeatable water outcomes, not to run every site as a custom project.",
    "designPrinciples": [
      "Keep ownership clear between site-intelligence, water-performance, enterprise-value, and service-operations teams.",
      "Use shared data and workflow products to scale expertise instead of expanding ad hoc manual service.",
      "Tie team missions directly to customer and business KPIs, not only to internal platform outputs."
    ],
    "staffingPrinciple": "Prefer mixed product, data, engineering, and domain-expert teams of roughly 60-90 FTE for each major product area so the full domain totals roughly 400-500 FTE.",
    "groupingPrinciple": "Group teams by durable product area so ownership of data, workflows, and outcomes stays understandable.",
    "groupLeadershipPrinciple": "Use product-area leaders with strong domain and data credibility rather than centralizing all decision-making in architecture or field operations."
  },
