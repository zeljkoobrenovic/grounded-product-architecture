  "orgDesign": {
    "domainId": "travel-accommodations-marketplace",
    "domainName": "Travel Accommodations Marketplace",
    "companyProfile": "Global travel marketplace centered on accommodation demand, partner supply, payments, servicing, and high-scale marketplace economics.",
    "operatingModel": "Traveler-facing teams own discovery, booking, and trip confidence while partner-facing teams own supply quality, connectivity, and commercial performance. Shared trust, payments, intelligence, and platform teams provide cross-marketplace control functions.",
    "designPrinciples": [
      "Keep traveler conversion and partner supply quality in the same operating system because marketplace economics depend on both at once.",
      "Treat payments, trust, and connectivity as first-class shared capabilities rather than product afterthoughts.",
      "Separate hotel-style commercial depth from small-host simplicity while keeping a common marketplace core."
    ],
    "staffingPrinciple": "Prefer teams of roughly 8-11 FTE with clear journey or capability ownership.",
    "groupingPrinciple": "Use top-level groups for traveler growth, partner growth, and marketplace foundations.",
    "groupLeadershipPrinciple": "Use lightweight leadership where multiple teams share one operating loop."
  },
