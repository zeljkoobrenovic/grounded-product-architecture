{
  "orgDesign": {
    "domainId": "mental-wellbeing-community-platform",
    "domainName": "Mental Wellbeing Community Platform",
    "companyProfile": "Digital mental wellbeing platform centered on member support, employer-sponsored access, contributor supply, and privacy-sensitive trust operations.",
    "operatingModel": "Member-facing teams own support discovery, community, and habit loops. Employer teams own onboarding, account health, and reporting. Contributor teams own supply, publishing, and event delivery. Shared trust and intelligence teams own privacy, moderation, identity, and data products.",
    "designPrinciples": [
      "Keep support discovery, community participation, and habit loops tightly connected because member trust compounds through repeated use.",
      "Separate employer operations from member experience so privacy and confidentiality remain explicit by design.",
      "Treat contributor operations and trust as product capabilities rather than back-office support because the product depends on daily quality supply."
    ],
    "staffingPrinciple": "Prefer teams of roughly 7-9 FTE with explicit customer or capability ownership.",
    "groupingPrinciple": "Use top-level groups for member growth, employer solutions, contributor network, and trust and intelligence.",
    "groupLeadershipPrinciple": "Use lightweight product and engineering leadership across groups tied to shared member, employer, and trust metrics."
  },
