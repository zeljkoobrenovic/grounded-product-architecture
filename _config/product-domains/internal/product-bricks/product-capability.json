{
  "metadata": {
    "title": "Product Capabilities",
    "description": "Outcome-based product capabilities for the Internal domain, focused on revenue visibility, governed execution, and internal operating leverage.",
    "definitions": {
      "productCapability": "A high-level, outcome-based ability that delivers customer or business value.",
      "productBrick": "A reusable implementation-facing building block used to realize one or more product capabilities."
    },
    "sources": [
      "https://www.salesforce.com/sales/revenue-intelligence/",
      "https://www.salesforce.com/blog/revenue-intelligence/"
    ]
  },
  "capabilities": [
    {
      "id": "ops-user-see-one-revenue-picture",
      "group": "Revenue Operations User Experience",
      "name": "See One Revenue Picture",
      "type": "outcome-based-capability",
      "description": "Help revenue operations users work from a single, trusted view of accounts, opportunities, and revenue data.",
      "outcomes": [
        "Less time reconciling conflicting data",
        "Higher confidence in operational decisions"
      ],
      "brickDependencies": [
        {
          "targetBrickId": "urdm",
          "type": "composition"
        },
        {
          "targetBrickId": "iaam",
          "type": "composition"
        }
      ],
      "externalSystemsThisCapabilityDependsOn": [
        {
          "system": "CRM and ERP Platforms",
          "type": "enterprise-system",
          "interface": "Enterprise APIs and pipelines",
          "description": "Provide source records for the unified view."
        }
      ],
      "flows": [
        "Open revenue workspace",
        "Merge cross-system context",
        "Review account truth",
        "Navigate shared metrics"
      ]
    },
