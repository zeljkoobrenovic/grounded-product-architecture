{
  "metadata": {
    "title": "Product Experiences",
    "description": "Outcome-based product experiences for the Online Retail Marketplace domain, covering shoppers, sellers, retail media, and marketplace foundations.",
    "definitions": {
      "productBrick": "A reusable implementation-facing building block used to realize one or more product experiences.",
      "productCapability": "A high-level, outcome-based experience that delivers customer or business value."
    },
    "sources": [
      "https://www.aboutamazon.com/news/operations/amazon-fastest-delivery-speeds-ever-prime-2025",
      "https://www.aboutamazon.com/news/retail/amazon-rufus",
      "https://sell.amazon.com/fulfillment-by-amazon",
      "https://sell.amazon.com/brand-registry",
      "https://advertising.amazon.com/",
      "https://advertising.amazon.com/solutions/products/amazon-marketing-cloud"
    ],
    "flowModelVersion": "3.2",
    "flowModelNote": "Each experience carries only experience-specific flows. Each flow step lists the bricks and external systems used inside that experience."
  },
  "rootGroups": [
    {
      "name": "Shopper Journey",
      "description": "",
      "subGroups": [],
      "capabilities": [
        {
          "id": "find-and-buy-confidently",
          "name": "Find and Buy the Right Product Confidently",
          "type": "outcome-based-experience",
          "description": "Help shoppers turn intent into confident orders with low search friction and strong trust signals.",
          "outcomes": [
            "Higher order frequency",
            "Higher detail-to-order conversion"
          ],
          "brickDependencies": [
            {
              "targetBrickId": "home",
              "type": "composition"
            },
            {
              "targetBrickId": "sear",
              "type": "composition"
            },
            {
              "targetBrickId": "rufu",
              "type": "composition"
            },
            {
              "targetBrickId": "pdet",
              "type": "composition"
            },
            {
              "targetBrickId": "revi",
              "type": "composition"
            },
            {
              "targetBrickId": "chec",
              "type": "composition"
            }
          ],
          "flows": [
            {
              "id": "find-and-buy-confidently-flow",
              "title": "Find and Buy the Right Product Confidently",
              "description": "From initial shopping intent to completed purchase.",
              "steps": [
                {
                  "id": "enter-a-shopping-mission",
                  "title": "Enter a shopping mission",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "home",
                      "name": "Shopping Home & Entry",
                      "description": "Personalized entry surfaces for household shopping moments.",
                      "how": "Creates fast paths into relevant shopping missions."
                    },
                    {
                      "type": "brick",
                      "id": "sear",
                      "name": "Search, Browse & Facets",
                      "description": "Search and browse across catalog and categories.",
                      "how": "Resolves explicit intent quickly."
                    }
                  ]
                },
                {
                  "id": "clarify-and-compare-options",
                  "title": "Clarify and compare options",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "rufu",
                      "name": "AI Shopping Assistant",
                      "description": "Guided shopping assistance for broad or uncertain intent.",
                      "how": "Reduces product-evaluation effort."
                    },
                    {
                      "type": "brick",
                      "id": "pdet",
                      "name": "Product Detail Experience",
                      "description": "Offer, content, and compatibility decision surface.",
                      "how": "Helps shoppers judge fit and value."
                    },
                    {
                      "type": "brick",
                      "id": "revi",
                      "name": "Reviews, Ratings & Q&A",
                      "description": "Review and answer system for shopper trust.",
                      "how": "Adds confidence before purchase."
                    }
                  ]
                },
                {
                  "id": "commit-to-purchase",
                  "title": "Commit to purchase",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "cart",
                      "name": "Cart & Save-for-Later",
                      "description": "Basket management before checkout.",
                      "how": "Stages conversion with low friction."
                    },
                    {
                      "type": "brick",
                      "id": "chec",
                      "name": "Checkout & Payments",
                      "description": "Checkout and transaction completion flow.",
                      "how": "Turns intent into a completed order."
                    }
                  ]
                }
              ]
            }
          ],
          "externalSystemsThisCapabilityDependsOn": [],
          "icon": "find-and-buy-confidently.png"
        },
        {
          "id": "receive-and-recover-reliably",
          "name": "Receive and Recover Reliably",
          "type": "outcome-based-experience",
          "description": "Turn a completed order into a retained shopper habit through accurate delivery, easy tracking, and low-effort issue resolution.",
          "outcomes": [
            "Higher Prime retention",
            "Higher self-service issue resolution"
          ],
          "brickDependencies": [
            {
              "targetBrickId": "prim",
              "type": "composition"
            },
            {
              "targetBrickId": "orde",
              "type": "composition"
            },
            {
              "targetBrickId": "deli",
              "type": "composition"
            },
            {
              "targetBrickId": "retu",
              "type": "composition"
            },
            {
              "targetBrickId": "care",
              "type": "composition"
            }
          ],
          "flows": [
            {
              "id": "receive-and-recover-reliably-flow",
              "title": "Receive and Recover Reliably",
              "description": "From placed order into trusted delivery and resolution.",
              "steps": [
                {
                  "id": "track-and-trust-the-promise",
                  "title": "Track and trust the promise",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "prim",
                      "name": "Prime Membership & Benefits",
                      "description": "Prime state and benefit visibility.",
                      "how": "Frames the value expectation for the order."
                    },
                    {
                      "type": "brick",
                      "id": "orde",
                      "name": "Order Management & Tracking",
                      "description": "Order and shipment visibility.",
                      "how": "Makes promise progress legible to shoppers."
                    },
                    {
                      "type": "brick",
                      "id": "deli",
                      "name": "Delivery Promise & Last Mile",
                      "description": "Promise calculation and last-mile eventing.",
                      "how": "Determines whether the delivery expectation is met."
                    }
                  ]
                },
                {
                  "id": "resolve-a-problem-if-needed",
                  "title": "Resolve a problem if needed",
                  "dependencies": [
                    {
                      "type": "brick",
                      "id": "retu",
                      "name": "Returns, Refunds & Exchanges",
                      "description": "Return and refund workflow.",
                      "how": "Handles common post-purchase issues."
                    },
                    {
                      "type": "brick",
                      "id": "care",
                      "name": "Customer Care & Resolution",
                      "description": "Case handling and escalations.",
                      "how": "Recovers issues that self-service cannot complete alone."
                    }
                  ]
                }
              ]
            }
          ],
          "externalSystemsThisCapabilityDependsOn": [],
          "icon": "receive-and-recover-reliably.png"
        }
      ]
    },
