          "type": "outcome-based-experience",
          "description": "Protect shoppers, sellers, and brands through shared account, abuse, authenticity, and support controls.",
          "outcomes": [
            "Lower abuse and counterfeit risk",
            "Higher shopper and seller trust"
          ],
          "brickDependencies": [
