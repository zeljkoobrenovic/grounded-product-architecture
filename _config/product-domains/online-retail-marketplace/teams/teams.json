  "orgDesign": {
    "domainId": "online-retail-marketplace",
    "domainName": "Online Retail Marketplace",
    "companyProfile": "Scaled online retail marketplace centered on shopper convenience, marketplace supply, Prime fulfillment, retail media, and platform trust.",
    "operatingModel": "Shopper-facing teams own discovery, detail, conversion, and Prime retention. Seller teams own onboarding, catalog, fulfillment, and commercial visibility. Retail media teams own sponsored products, DSP, and measurement. Foundation teams own identity, trust, recommendations, and shared commerce intelligence.",
    "designPrinciples": [
      "Keep discovery, detail, cart, checkout, and Prime conversion in one shopper feedback loop.",
      "Keep seller growth and fulfillment economics closely linked because commercial outcomes depend on operational health.",
      "Keep ads close to retail signals so media optimization stays grounded in commerce reality."
    ],
    "staffingPrinciple": "Prefer teams of roughly 8-10 FTE with explicit customer or product-brick ownership.",
    "groupingPrinciple": "Use top-level groups for shopper growth, prime operations, seller platform, retail media, and marketplace foundations.",
    "groupLeadershipPrinciple": "Use lightweight cross-group leadership tied to Prime retention, seller growth, and advertising economics."
