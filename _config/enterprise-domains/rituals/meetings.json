{
  "schemaVersion": "1.0",
  "scope": "product-and-technology-organization",
  "description": "Core recurring meetings that help a typical product and technology organization align strategy, execution, learning, and operational control.",
  "meetings": [
    {
      "id": "weekly-product-triad",
      "title": "Product Triad Sync",
      "category": "product-delivery",
      "description": "A weekly working session for the product manager, engineering lead, and design lead to align on priorities, risks, decisions, and near-term delivery.",
      "goal": "Keep product decisions, delivery trade-offs, and customer outcomes aligned within the core squad leadership group.",
      "participants": {
        "required": [
          "Product Manager",
          "Engineering Lead",
          "Design Lead"
        ],
        "optional": [
          "Data Analyst",
          "Tech Lead",
          "Research Lead"
        ]
      },
      "owner": "Product Manager",
      "cadence": "weekly",
      "durationMinutes": 60,
      "format": "decision-and-planning",
      "inputs": [
        "Current sprint or delivery plan",
        "Open decisions and blockers",
        "Recent customer feedback",
        "KPI movement"
      ],
      "outputs": [
        "Prioritized actions",
        "Resolved decisions",
        "Escalations",
        "Updated ownership"
      ]
    },
    {
      "id": "daily-delivery-standup",
      "title": "Delivery Standup",
      "category": "delivery",
      "description": "A short daily check-in for the squad to surface progress, dependencies, blockers, and coordination needs.",
      "goal": "Maintain delivery flow and expose impediments early without turning the meeting into a status theater.",
      "participants": {
        "required": [
          "Engineers",
          "Engineering Lead",
          "Product Manager"
        ],
        "optional": [
          "Designer",
          "QA Engineer",
          "Data Engineer"
        ]
      },
      "owner": "Engineering Lead",
      "cadence": "daily",
      "durationMinutes": 15,
      "format": "coordination",
      "inputs": [
        "Active work items",
        "Blockers",
        "Upcoming handoffs"
      ],
      "outputs": [
        "Escalated blockers",
        "Coordination actions",
        "Updated delivery expectations"
      ]
    },
    {
      "id": "weekly-backlog-refinement",
      "title": "Backlog Refinement",
      "category": "delivery-planning",
      "description": "A recurring session to clarify upcoming work, break down scope, confirm dependencies, and prepare items for implementation.",
      "goal": "Ensure the next slice of work is small, understood, and actionable before the team commits to it.",
      "participants": {
        "required": [
          "Product Manager",
          "Engineering Lead",
          "Engineers"
        ],
        "optional": [
          "Designer",
          "QA Engineer",
          "Data Analyst"
        ]
      },
      "owner": "Product Manager",
      "cadence": "weekly",
      "durationMinutes": 60,
      "format": "working-session",
      "inputs": [
        "Ranked backlog",
        "Draft requirements",
        "Technical constraints",
        "Designs or flows"
      ],
      "outputs": [
        "Refined backlog items",
        "Open questions",
        "Sizing readiness",
        "Dependency notes"
      ]
    },
    {
      "id": "biweekly-sprint-planning",
      "title": "Sprint Planning",
      "category": "delivery-planning",
      "description": "A planning meeting where the team agrees on the work to take into the next sprint and how it will be executed.",
      "goal": "Create a realistic short-term delivery plan with clear ownership and explicit trade-offs.",
      "participants": {
        "required": [
          "Product Manager",
          "Engineering Lead",
          "Engineers"
        ],
        "optional": [
          "Designer",
          "QA Engineer"
        ]
      },
      "owner": "Engineering Lead",
      "cadence": "biweekly",
      "durationMinutes": 90,
      "format": "planning",
      "inputs": [
        "Refined backlog",
        "Capacity assumptions",
        "Carry-over work",
        "Release commitments"
      ],
      "outputs": [
        "Sprint goal",
        "Committed sprint backlog",
        "Capacity adjustments",
        "Identified risks"
      ]
    },
    {
      "id": "biweekly-sprint-review",
      "title": "Sprint Review",
      "category": "delivery-learning",
      "description": "A demo-focused review of completed work with stakeholders to validate progress, learn from feedback, and confirm next steps.",
      "goal": "Turn completed work into shared understanding, stakeholder feedback, and better prioritization decisions.",
      "participants": {
        "required": [
          "Product Manager",
          "Engineering Lead",
          "Engineers",
          "Design Lead"
        ],
        "optional": [
          "Business Stakeholders",
          "Customer Success",
          "Sales",
          "Operations"
        ]
      },
      "owner": "Product Manager",
      "cadence": "biweekly",
      "durationMinutes": 60,
      "format": "review",
      "inputs": [
        "Completed work",
        "Demo scenarios",
        "Acceptance criteria",
        "Open questions"
      ],
      "outputs": [
        "Stakeholder feedback",
        "Follow-up decisions",
        "Updated backlog priorities"
      ]
    },
    {
      "id": "biweekly-retrospective",
      "title": "Retrospective",
      "category": "team-health",
      "description": "A team reflection on what helped, what hurt, and what should change in the way the squad works.",
      "goal": "Improve delivery effectiveness, collaboration quality, and team health through concrete process changes.",
      "participants": {
        "required": [
          "Engineers",
          "Engineering Lead",
          "Product Manager"
        ],
        "optional": [
          "Designer",
          "QA Engineer"
        ]
      },
      "owner": "Engineering Lead",
      "cadence": "biweekly",
      "durationMinutes": 60,
      "format": "reflection",
      "inputs": [
        "Sprint outcomes",
        "Team observations",
        "Delivery pain points",
        "Incidents or interruptions"
      ],
      "outputs": [
        "Improvement actions",
        "Working agreement changes",
        "Ownership for follow-through"
      ]
    },
    {
      "id": "weekly-kpi-review",
      "title": "KPI Review",
      "category": "performance-management",
      "description": "A recurring review of customer, product, operational, and business metrics to understand movement and decide follow-up actions.",
      "goal": "Keep delivery connected to measurable outcomes rather than relying on anecdote or output volume alone.",
      "participants": {
        "required": [
          "Product Manager",
          "Engineering Lead",
          "Data Analyst"
        ],
        "optional": [
          "Design Lead",
          "Customer Success Lead",
          "Business Lead"
        ]
      },
      "owner": "Product Manager",
      "cadence": "weekly",
      "durationMinutes": 45,
      "format": "review-and-decision",
      "inputs": [
        "KPI dashboard",
        "Experiment results",
        "Customer support signals",
        "Operational trend data"
      ],
      "outputs": [
        "Investigations",
        "Priority changes",
        "Metric hypotheses",
        "Escalations"
      ]
    },
    {
      "id": "biweekly-customer-evidence-review",
      "title": "Customer Evidence Review",
      "category": "discovery",
      "description": "A structured review of research, support insights, sales feedback, usage patterns, and direct customer evidence.",
      "goal": "Continuously ground roadmap and design decisions in real customer behavior, needs, and pain points.",
      "participants": {
        "required": [
          "Product Manager",
          "Designer",
          "Research Lead"
        ],
        "optional": [
          "Engineering Lead",
          "Customer Success",
          "Sales",
          "Support"
        ]
      },
      "owner": "Design Lead",
      "cadence": "biweekly",
      "durationMinutes": 60,
      "format": "evidence-review",
      "inputs": [
        "Research notes",
        "Interview summaries",
        "Support themes",
        "Usage analytics"
      ],
      "outputs": [
        "Validated insights",
        "New problem statements",
        "Discovery actions",
        "Updated opportunity areas"
      ]
    },
    {
      "id": "monthly-roadmap-review",
      "title": "Roadmap Review",
      "category": "strategy-and-planning",
      "description": "A monthly check on roadmap assumptions, outcome progress, cross-team dependencies, and sequencing decisions.",
      "goal": "Keep the roadmap current, evidence-based, and synchronized with actual team capacity and business priorities.",
      "participants": {
        "required": [
          "Product Leaders",
          "Engineering Leaders",
          "Design Leaders"
        ],
        "optional": [
          "Data Lead",
          "Operations Lead",
          "Commercial Stakeholders"
        ]
      },
      "owner": "Head of Product",
      "cadence": "monthly",
      "durationMinutes": 90,
      "format": "review-and-alignment",
      "inputs": [
        "Outcome progress",
        "Roadmap changes",
        "Dependency map",
        "Customer and business signals"
      ],
      "outputs": [
        "Roadmap adjustments",
        "Reprioritization decisions",
        "Dependency resolutions",
        "Escalations to leadership"
      ]
    },
    {
      "id": "monthly-architecture-review",
      "title": "Architecture Review",
      "category": "technical-governance",
      "description": "A technical review of major design decisions, structural risks, platform direction, and significant implementation proposals.",
      "goal": "Protect long-term system quality while enabling teams to move with appropriate autonomy and guardrails.",
      "participants": {
        "required": [
          "Architect",
          "Engineering Leaders",
          "Tech Leads"
        ],
        "optional": [
          "Security Lead",
          "Product Manager",
          "Platform Lead"
        ]
      },
      "owner": "Chief Architect",
      "cadence": "monthly",
      "durationMinutes": 90,
      "format": "decision-review",
      "inputs": [
        "Architecture proposals",
        "System risks",
        "Technical debt themes",
        "Platform needs"
      ],
      "outputs": [
        "Approved design decisions",
        "Required follow-ups",
        "Standards or guardrail updates"
      ]
    },
    {
      "id": "monthly-release-readiness",
      "title": "Release Readiness Review",
      "category": "release-management",
      "description": "A checkpoint before significant releases to assess scope completeness, quality, support readiness, and operational risk.",
      "goal": "Reduce release surprises by aligning product, engineering, operations, and go-to-market readiness before launch.",
      "participants": {
        "required": [
          "Product Manager",
          "Engineering Lead",
          "QA Lead",
          "Operations Lead"
        ],
        "optional": [
          "Support Lead",
          "Marketing Lead",
          "Customer Success Lead",
          "Security Lead"
        ]
      },
      "owner": "Engineering Lead",
      "cadence": "monthly",
      "durationMinutes": 60,
      "format": "risk-review",
      "inputs": [
        "Release scope",
        "Testing status",
        "Known issues",
        "Rollout plan",
        "Support plan"
      ],
      "outputs": [
        "Go or no-go decision",
        "Risk mitigations",
        "Launch checklist updates",
        "Communication actions"
      ]
    },
    {
      "id": "monthly-incident-review",
      "title": "Incident and Reliability Review",
      "category": "operations",
      "description": "A recurring review of production incidents, operational risk trends, response quality, and systemic reliability issues.",
      "goal": "Strengthen reliability by turning operational failures into learning, ownership, and preventive improvements.",
      "participants": {
        "required": [
          "Engineering Lead",
          "SRE or Platform Lead",
          "Operations Lead"
        ],
        "optional": [
          "Product Manager",
          "Security Lead",
          "Support Lead"
        ]
      },
      "owner": "SRE or Platform Lead",
      "cadence": "monthly",
      "durationMinutes": 60,
      "format": "operational-review",
      "inputs": [
        "Incident summaries",
        "Reliability metrics",
        "Postmortems",
        "On-call observations"
      ],
      "outputs": [
        "Reliability actions",
        "Prevention work",
        "Escalated systemic risks"
      ]
    },
    {
      "id": "quarterly-okr-planning",
      "title": "Quarterly OKR Planning",
      "category": "strategy-and-planning",
      "description": "A quarterly planning ritual to define or refresh objectives, key results, priorities, and investment focus for the next quarter.",
      "goal": "Translate strategy into a small set of measurable priorities that guide roadmap and delivery choices.",
      "participants": {
        "required": [
          "Product Leaders",
          "Engineering Leaders",
          "Design Leaders",
          "Business Leaders"
        ],
        "optional": [
          "Finance Lead",
          "Data Lead",
          "Operations Lead"
        ]
      },
      "owner": "Head of Product",
      "cadence": "quarterly",
      "durationMinutes": 180,
      "format": "planning",
      "inputs": [
        "Strategy themes",
        "Previous quarter results",
        "KPI trends",
        "Customer evidence",
        "Capacity outlook"
      ],
      "outputs": [
        "Quarterly objectives",
        "Key results",
        "Priority initiatives",
        "Explicit non-goals"
      ]
    },
    {
      "id": "quarterly-portfolio-review",
      "title": "Portfolio Review",
      "category": "portfolio-governance",
      "description": "A leadership review of product bets, cross-domain investments, delivery health, and strategic trade-offs across the portfolio.",
      "goal": "Make explicit portfolio-level investment decisions rather than letting priorities drift through local optimization.",
      "participants": {
        "required": [
          "Executive Sponsor",
          "Product Leaders",
          "Engineering Leaders",
          "Finance Lead"
        ],
        "optional": [
          "Commercial Lead",
          "Operations Lead",
          "Strategy Lead"
        ]
      },
      "owner": "Chief Product Officer",
      "cadence": "quarterly",
      "durationMinutes": 120,
      "format": "governance-review",
      "inputs": [
        "Portfolio roadmap",
        "Investment allocation",
        "Outcome performance",
        "Major risks and dependencies"
      ],
      "outputs": [
        "Investment shifts",
        "Portfolio decisions",
        "Escalated dependencies",
        "Leadership commitments"
      ]
    },
    {
      "id": "quarterly-technology-health-review",
      "title": "Technology Health Review",
      "category": "technical-governance",
      "description": "A quarterly leadership review of architecture health, platform maturity, security exposure, reliability, and technical debt posture.",
      "goal": "Prevent structural technology risks from being ignored when delivery pressure is high.",
      "participants": {
        "required": [
          "CTO or VP Engineering",
          "Architect",
          "Engineering Managers",
          "Security Lead"
        ],
        "optional": [
          "Product Leaders",
          "Platform Lead",
          "SRE Lead"
        ]
      },
      "owner": "CTO or VP Engineering",
      "cadence": "quarterly",
      "durationMinutes": 90,
      "format": "health-review",
      "inputs": [
        "Reliability trends",
        "Security posture",
        "Technical debt themes",
        "Platform bottlenecks",
        "Architecture risks"
      ],
      "outputs": [
        "Technical investment priorities",
        "Risk mitigations",
        "Standards updates",
        "Leadership decisions"
      ]
    },
    {
      "id": "quarterly-business-review",
      "title": "Quarterly Business Review",
      "category": "business-governance",
      "description": "A cross-functional review of business performance, product outcomes, major learnings, and next-quarter implications.",
      "goal": "Connect product and technology execution to commercial performance, customer impact, and strategic accountability.",
      "participants": {
        "required": [
          "Executive Team",
          "Product Leaders",
          "Engineering Leaders",
          "Finance Lead"
        ],
        "optional": [
          "Sales Lead",
          "Marketing Lead",
          "Operations Lead",
          "Customer Success Lead"
        ]
      },
      "owner": "CEO or General Manager",
      "cadence": "quarterly",
      "durationMinutes": 120,
      "format": "executive-review",
      "inputs": [
        "Business KPIs",
        "Customer KPIs",
        "Goal results",
        "Major releases and initiatives",
        "Key risks and opportunities"
      ],
      "outputs": [
        "Executive alignment",
        "Priority shifts",
        "Investment guidance",
        "Cross-functional commitments"
      ]
    }
  ]
}
