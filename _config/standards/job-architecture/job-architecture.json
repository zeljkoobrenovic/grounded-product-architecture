{
  "metadata": {
    "id": "job-architecture",
    "name": "Product and Technology Job Architecture",
    "companyProfile": "EU-based product company with around 500 employees",
    "scope": [
      "product management",
      "product design",
      "user research",
      "product operations",
      "software engineering",
      "platform and site reliability engineering",
      "data engineering and analytics",
      "quality engineering",
      "security engineering",
      "engineering management"
    ],
    "currency": "EUR",
    "salaryUnit": "gross annual base salary",
    "salaryReferenceYear": 2026,
    "marketReference": "Ranges are calibrated for a mid-size EU technology employer, anchored roughly between France, Germany, and the Netherlands rather than London- or Zurich-level pay."
  },
  "compensationPhilosophy": {
    "payPositioning": "Target around the 55th to 65th percentile of the relevant EU talent market for core product and technology roles.",
    "geographicApproach": "Use one primary EU salary architecture with limited local adjustment rather than country-by-country ladders for every market.",
    "bonusPolicy": {
      "icTypicalTargetPercent": "0-10",
      "managerTypicalTargetPercent": "10-20",
      "directorTypicalTargetPercent": "15-25",
      "vpTypicalTargetPercent": "20-35",
      "executiveTypicalTargetPercent": "25-45"
    },
    "equityPolicy": "Equity or long-term incentive grants increase with seniority, scarce skills, and leadership scope but do not replace fair base salary positioning.",
    "reviewCycle": "Salary reviews annually; promotions and out-of-cycle corrections only when role scope has materially changed."
  },
  "careerFramework": {
    "tracks": [
      {
        "id": "ic",
        "name": "Individual Contributor",
        "description": "Primary path for people who increase scope through craft depth, cross-team influence, and business impact."
      },
      {
        "id": "management",
        "name": "Management",
        "description": "Primary path for people who increase scope through team leadership, organizational design, and portfolio accountability."
      }
    ],
    "levelDefinitions": [
      {
        "id": "l1",
        "name": "Associate",
        "track": "ic",
        "scope": "Learns the domain, contributes to a clearly bounded area, and requires close support.",
        "impact": "Improves local execution quality and delivers scoped work with guidance.",
        "autonomy": "Low to moderate",
        "typicalPromotionWindowMonths": "12-24"
      },
      {
        "id": "l2",
        "name": "Mid-level",
        "track": "ic",
        "scope": "Owns a meaningful area of work end to end inside one team.",
        "impact": "Delivers reliable outcomes for a team-level problem space.",
        "autonomy": "Moderate",
        "typicalPromotionWindowMonths": "18-30"
      },
      {
        "id": "l3",
        "name": "Senior",
        "track": "ic",
        "scope": "Owns a complex area, makes tradeoffs independently, and raises the quality bar for the team.",
        "impact": "Materially improves product, system, or delivery outcomes at team scope.",
        "autonomy": "High",
        "typicalPromotionWindowMonths": "24-36"
      },
      {
        "id": "l4",
        "name": "Staff",
        "track": "ic",
        "scope": "Shapes strategy and technical or functional direction across multiple teams or one group.",
        "impact": "Solves structural problems, aligns teams, and improves leverage across a wider area.",
        "autonomy": "Very high",
        "typicalPromotionWindowMonths": "30-48"
      },
      {
        "id": "l5",
        "name": "Principal",
        "track": "ic",
        "scope": "Drives architecture, product, or operating model decisions across a major domain.",
        "impact": "Creates durable company-level leverage and standards.",
        "autonomy": "Company-level"
      },
      {
        "id": "m1",
        "name": "Manager",
        "track": "management",
        "scope": "Leads one team, owns staffing quality, delivery health, and team-level performance.",
        "impact": "Improves outcomes through people leadership and execution systems.",
        "autonomy": "High"
      },
      {
        "id": "m2",
        "name": "Senior Manager / Group Manager",
        "track": "management",
        "scope": "Leads multiple teams or a larger function slice with clear portfolio tradeoffs.",
        "impact": "Aligns a group around priorities, staffing, and operating cadence.",
        "autonomy": "Very high"
      },
      {
        "id": "m3",
        "name": "Director",
        "track": "management",
        "scope": "Leads a product or technology group, shapes org design, and owns multi-team outcomes.",
        "impact": "Delivers domain-level results through organizational leadership.",
        "autonomy": "Domain-level"
      },
      {
        "id": "m4",
        "name": "Senior Director / Head of",
        "track": "management",
        "scope": "Leads a major function or portfolio with broad cross-company dependencies.",
        "impact": "Shapes company priorities, investment choices, and organizational maturity.",
        "autonomy": "Company-level"
      },
      {
        "id": "m5",
        "name": "Vice President",
        "track": "management",
        "scope": "Leads a large product or technology function through multiple directors and owns company-critical capability areas.",
        "impact": "Translates company strategy into functional investment choices, organization design, and multi-year capability development.",
        "autonomy": "Executive-level"
      },
      {
        "id": "m6",
        "name": "C-Level Executive",
        "track": "management",
        "scope": "Owns the full company product or technology agenda and represents the function at executive and board level.",
        "impact": "Shapes enterprise strategy, allocates top-level investment, and is accountable for company-wide outcomes through the function.",
        "autonomy": "Company-wide"
      }
    ],
    "promotionCriteria": [
      "Promotion is based on sustained performance at the next level, not tenure alone.",
      "Leveling evaluates scope, complexity, autonomy, influence, and business impact together.",
      "A person should already be operating consistently at the target level for at least one or two review cycles before promotion.",
      "Compensation movement without promotion is allowed for market correction, retention, or strong performance inside a level."
    ],
    "evaluationDimensions": [
      "craft and functional judgment",
      "scope and complexity handled",
      "autonomy and decision quality",
      "execution reliability",
      "stakeholder influence",
      "people and organizational leverage where relevant",
      "customer and business impact"
    ]
  },
