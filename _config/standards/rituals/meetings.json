{
  "schemaVersion": "1.0",
  "scope": "bike-mobility-domain",
  "description": "Recurring meetings for a bike-mobility organization that must coordinate employer launches, rider experience, dealer and service operations, finance control, and emerging fleet offers.",
  "meetings": [
    {
      "id": "weekly-product-triad",
      "title": "Product Triad Sync",
      "category": "product-delivery",
      "description": "A weekly working session for the product manager, engineering lead, and design lead to align on priorities, risks, and decisions inside each bike-mobility squad.",
      "goal": "Keep product choices, delivery trade-offs, and customer outcomes aligned within the local squad leadership group.",
      "participants": {
        "required": [
          "Product Manager",
          "Engineering Lead",
          "Design Lead"
        ],
        "optional": [
          "Data Analyst",
          "Domain Specialist",
          "Research Lead"
        ]
      },
      "owner": "Product Manager",
      "cadence": "weekly",
      "durationMinutes": 60,
      "format": "decision-and-planning",
      "inputs": [
        "Active roadmap slice",
        "Open customer and operational risks",
        "Recent KPI movement",
        "Current delivery blockers"
      ],
      "outputs": [
        "Resolved product decisions",
        "Updated priorities",
        "Escalations",
        "Explicit ownership"
      ]
    },
    {
      "id": "daily-delivery-standup",
      "title": "Delivery Standup",
      "category": "delivery",
      "description": "A short daily coordination check for the squad to surface progress, blockers, and handoffs across engineering, design, QA, and operational partners.",
      "goal": "Maintain delivery flow and expose implementation or dependency issues early.",
      "participants": {
        "required": [
          "Engineers",
          "Engineering Lead",
          "Product Manager"
        ],
        "optional": [
          "Designer",
          "QA Engineer",
          "Domain Specialist"
        ]
      },
      "owner": "Engineering Lead",
      "cadence": "daily",
      "durationMinutes": 15,
      "format": "coordination",
      "inputs": [
        "Active work items",
        "Current blockers",
        "Planned handoffs"
      ],
      "outputs": [
        "Escalated blockers",
        "Daily coordination actions",
        "Updated expectations"
      ]
    },
    {
      "id": "weekly-employer-launch-readiness",
      "title": "Employer Launch Readiness",
      "category": "go-to-market-operations",
      "description": "A weekly review of employer launches in flight across policy setup, payroll integration, communications readiness, and billing control.",
      "goal": "Reduce go-live lead time and stop employer launches from stalling between commercial commitment and operational readiness.",
      "participants": {
        "required": [
          "Employer Platform PM",
          "Implementation Lead",
          "Employer Integrations Lead",
          "Finance Operations Lead"
        ],
        "optional": [
          "Customer Success Lead",
          "Country Operations Lead",
          "Data Analyst"
        ]
      },
      "owner": "Employer Platform PM",
      "cadence": "weekly",
      "durationMinutes": 60,
      "format": "operational-review",
      "inputs": [
        "Employer rollout tracker",
        "Integration readiness status",
        "Open policy exceptions",
        "Launch risk log"
      ],
      "outputs": [
        "Go-live risk decisions",
        "Escalated employer dependencies",
        "Updated launch dates",
        "Named owners for blocked items"
      ]
    },
    {
      "id": "weekly-rider-service-kpi-review",
      "title": "Rider and Service KPI Review",
      "category": "performance-management",
      "description": "A weekly metric review focused on rider conversion, incident recovery, service throughput, and active-rider health.",
      "goal": "Keep rider growth and rider uptime connected rather than optimizing conversion and service in isolation.",
      "participants": {
        "required": [
          "Rider Growth PM",
          "Service Orchestration PM",
          "Data Analyst",
          "Engineering Leads"
        ],
        "optional": [
          "Claims Operations Lead",
          "Support Lead",
          "Design Lead"
        ]
      },
      "owner": "Rider Growth PM",
      "cadence": "weekly",
      "durationMinutes": 45,
      "format": "review-and-decision",
      "inputs": [
        "Funnel KPIs",
        "Active rider cohorts",
        "Incident recovery metrics",
        "Support and claims themes"
      ],
      "outputs": [
        "Investigations",
        "Priority shifts",
        "Metric hypotheses",
        "Escalations to partner or finance teams"
      ]
    },
    {
      "id": "biweekly-customer-evidence-review",
      "title": "Customer Evidence Review",
      "category": "discovery",
      "description": "A structured review of employer feedback, rider interviews, dealer pain points, pilot fleet learnings, and support evidence.",
      "goal": "Continuously ground roadmap and operating-model decisions in real customer and partner evidence.",
      "participants": {
        "required": [
          "Product Managers",
          "Design Leads",
          "Research Lead"
        ],
        "optional": [
          "Engineering Lead",
          "Customer Success",
          "Partner Operations",
          "Support"
        ]
      },
      "owner": "Research Lead",
      "cadence": "biweekly",
      "durationMinutes": 60,
      "format": "evidence-review",
      "inputs": [
        "Interview summaries",
        "Support themes",
        "Partner feedback",
        "Usage analytics"
      ],
      "outputs": [
        "Validated insights",
        "New problem statements",
        "Discovery actions",
        "Updated opportunity areas"
      ]
    },
    {
      "id": "biweekly-dealer-ops-sync",
      "title": "Dealer and Service Ops Sync",
      "category": "partner-operations",
      "description": "A biweekly operating review of dealer onboarding, stock constraints, workshop throughput, claims bottlenecks, and reimbursement friction.",
      "goal": "Keep the dealer ecosystem healthy enough to support rider trust and employer expansion.",
      "participants": {
        "required": [
          "Partner Network Lead",
          "Service Orchestration Lead",
          "Claims Operations Lead",
          "Finance Operations Lead"
        ],
        "optional": [
          "Country Operations Lead",
          "Data Analyst",
          "Customer Success Lead"
        ]
      },
      "owner": "Partner Network Lead",
      "cadence": "biweekly",
      "durationMinutes": 60,
      "format": "operational-review",
      "inputs": [
        "Partner scorecards",
        "Service turnaround trends",
        "Reimbursement-cycle metrics",
        "Coverage gaps and churn signals"
      ],
      "outputs": [
        "Partner risk escalations",
        "Operational fixes",
        "Coverage actions",
        "Ownership for payout and service issues"
      ]
    },
    {
      "id": "monthly-roadmap-review",
      "title": "Roadmap Review",
      "category": "strategy-and-planning",
      "description": "A monthly review of roadmap assumptions, cross-team dependencies, current-quarter goal progress, and sequencing across employer, rider, partner, finance, and fleet streams.",
      "goal": "Keep the bike-mobility roadmap current, evidence-based, and synchronized with actual capacity and market needs.",
      "participants": {
        "required": [
          "Product Leaders",
          "Engineering Leaders",
          "Design Leaders"
        ],
        "optional": [
          "Data Lead",
          "Operations Lead",
          "Commercial Stakeholders"
        ]
      },
      "owner": "Head of Product",
      "cadence": "monthly",
      "durationMinutes": 90,
      "format": "review-and-alignment",
      "inputs": [
        "Goal progress",
        "Initiative status",
        "Dependency map",
        "Customer and business signals"
      ],
      "outputs": [
        "Roadmap adjustments",
        "Reprioritization decisions",
        "Dependency resolutions",
        "Leadership escalations"
      ]
    },
    {
      "id": "monthly-claims-and-settlement-review",
      "title": "Claims and Settlement Review",
      "category": "financial-governance",
      "description": "A monthly review of claims turnaround, reimbursement cycle time, settlement integrity, and margin leakage across riders, dealers, and employers.",
      "goal": "Prevent claims and financial control work from degrading rider trust, dealer economics, or unit margin.",
      "participants": {
        "required": [
          "Claims Operations Lead",
          "Finance Reconciliation Lead",
          "Service Orchestration Lead",
          "Data Analyst"
        ],
        "optional": [
          "Employer Platform PM",
          "Partner Network Lead",
          "Compliance Lead"
        ]
      },
      "owner": "Finance Reconciliation Lead",
      "cadence": "monthly",
      "durationMinutes": 60,
      "format": "risk-review",
      "inputs": [
        "Claims aging report",
        "Reimbursement metrics",
        "Settlement exceptions",
        "Margin and leakage analysis"
      ],
      "outputs": [
        "Control improvements",
        "Escalated exception themes",
        "Prioritized fixes",
        "Risk owners"
      ]
    },
    {
      "id": "monthly-fleet-pilot-review",
      "title": "Fleet Pilot Review",
      "category": "growth-incubation",
      "description": "A monthly review of pooled-bike pilots covering utilization, downtime, trip substitution, service readiness, and expansion decisions.",
      "goal": "Decide whether fleet mobility should remain a pilot, be narrowed, or be scaled as a second growth line.",
      "participants": {
        "required": [
          "Fleet Operations Lead",
          "Service Orchestration Lead",
          "Data Lead",
          "Product Leader"
        ],
        "optional": [
          "Country Operations Lead",
          "Commercial Lead",
          "Platform Reliability Lead"
        ]
      },
      "owner": "Fleet Operations Lead",
      "cadence": "monthly",
      "durationMinutes": 60,
      "format": "review-and-decision",
      "inputs": [
        "Fleet utilization dashboard",
        "Downtime and maintenance data",
        "Pilot customer feedback",
        "Unit economics review"
      ],
      "outputs": [
        "Pilot continuation decisions",
        "Template changes",
        "Expansion or stop decisions",
        "Cross-team follow-up actions"
      ]
    },
    {
      "id": "monthly-architecture-review",
      "title": "Architecture Review",
      "category": "technical-governance",
      "description": "A technical review of major design decisions, structural risks, workflow-platform direction, and significant implementation proposals across the bike-mobility platform.",
      "goal": "Protect long-term system quality while enabling value-stream teams to move with appropriate autonomy and guardrails.",
      "participants": {
        "required": [
          "Chief Architect",
          "Engineering Leaders",
          "Tech Leads"
        ],
        "optional": [
          "Security Lead",
          "Product Manager",
          "Platform Lead"
        ]
      },
      "owner": "Chief Architect",
      "cadence": "monthly",
      "durationMinutes": 90,
      "format": "decision-review",
      "inputs": [
        "Architecture proposals",
        "System risks",
        "Workflow platform needs",
        "Integration and data constraints"
      ],
      "outputs": [
        "Approved design decisions",
        "Required follow-ups",
        "Standards updates"
      ]
    },
    {
      "id": "monthly-release-readiness",
      "title": "Release Readiness Review",
      "category": "release-management",
      "description": "A checkpoint before significant releases to assess scope completeness, support readiness, operational risk, and launch communication across employers, riders, dealers, and fleets.",
      "goal": "Reduce release surprises by aligning product, engineering, service, and operational readiness before launch.",
      "participants": {
        "required": [
          "Product Manager",
          "Engineering Lead",
          "QA Lead",
          "Operations Lead"
        ],
        "optional": [
          "Support Lead",
          "Customer Success Lead",
          "Finance Operations Lead",
          "Security Lead"
        ]
      },
      "owner": "Engineering Lead",
      "cadence": "monthly",
      "durationMinutes": 60,
      "format": "risk-review",
      "inputs": [
        "Release scope",
        "Testing status",
        "Known issues",
        "Rollout plan",
        "Support and communication plan"
      ],
      "outputs": [
        "Go or no-go decision",
        "Risk mitigations",
        "Launch checklist updates",
        "Communication actions"
      ]
    },
    {
      "id": "monthly-incident-review",
      "title": "Incident and Reliability Review",
      "category": "operations",
      "description": "A recurring review of incidents, rider-impacting outages, service disruptions, and systemic reliability risks across the bike-mobility platform.",
      "goal": "Turn operational failures into learning, ownership, and preventive reliability improvements.",
      "participants": {
        "required": [
          "Engineering Lead",
          "Platform Reliability Lead",
          "Operations Lead"
        ],
        "optional": [
          "Product Manager",
          "Security Lead",
          "Support Lead"
        ]
      },
      "owner": "Platform Reliability Lead",
      "cadence": "monthly",
      "durationMinutes": 60,
      "format": "operational-review",
      "inputs": [
        "Incident summaries",
        "Reliability metrics",
        "Postmortems",
        "Support escalations"
      ],
      "outputs": [
        "Reliability actions",
        "Prevention work",
        "Escalated systemic risks"
      ]
    },
    {
      "id": "quarterly-okr-planning",
      "title": "Quarterly Goal and Investment Planning",
      "category": "strategy-and-planning",
      "description": "A quarterly planning ritual to define or refresh objectives, key results, priorities, and investment focus across employer growth, rider trust, partner health, finance control, and fleet expansion.",
      "goal": "Translate bike-mobility strategy into a small set of measurable priorities that guide roadmap and delivery choices.",
      "participants": {
        "required": [
          "Product Leaders",
          "Engineering Leaders",
          "Design Leaders",
          "Business Leaders"
        ],
        "optional": [
          "Finance Lead",
          "Data Lead",
          "Operations Lead"
        ]
      },
      "owner": "Head of Product",
      "cadence": "quarterly",
      "durationMinutes": 180,
      "format": "planning",
      "inputs": [
        "Strategy themes",
        "Previous quarter results",
        "KPI trends",
        "Customer evidence",
        "Capacity outlook"
      ],
      "outputs": [
        "Quarterly objectives",
        "Key results",
        "Priority initiatives",
        "Explicit non-goals"
      ]
    },
    {
      "id": "quarterly-business-review",
      "title": "Quarterly Business Review",
      "category": "business-governance",
      "description": "A cross-functional review of business performance, product outcomes, partner economics, and next-quarter implications for the bike-mobility portfolio.",
      "goal": "Connect product and technology execution to commercial performance, rider and employer outcomes, and strategic accountability.",
      "participants": {
        "required": [
          "Executive Team",
          "Product Leaders",
          "Engineering Leaders",
          "Finance Lead"
        ],
        "optional": [
          "Sales Lead",
          "Operations Lead",
          "Customer Success Lead",
          "Country Managers"
        ]
      },
      "owner": "CEO or General Manager",
      "cadence": "quarterly",
      "durationMinutes": 120,
      "format": "executive-review",
      "inputs": [
        "Business KPIs",
        "Customer KPIs",
        "Goal results",
        "Major releases and initiatives",
        "Key risks and opportunities"
      ],
      "outputs": [
        "Executive alignment",
        "Priority shifts",
        "Investment guidance",
        "Cross-functional commitments"
      ]
    }
  ]
}
